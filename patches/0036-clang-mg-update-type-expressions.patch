index 000000000000..5480e6fcc4ba
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-predicate-static-local-constexpr.cpp
@@ -0,0 +1,27 @@
+// RUN: %clang_cc1 -std=c++20 -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+trait generator {
+  void generate();
+};
+
+trait builder {
+  int build();
+};
+
+struct ninja_backend {
+  void generate();
+  int build();
+};
+
+struct empty_backend {};
+
+template <typename Backend>
+constexpr bool has_generator_static_local() {
+  using backend_t = Backend;
+  static constexpr bool is_gen = generator && backend_t;
+  return is_gen;
+}
+
+static_assert(has_generator_static_local<ninja_backend>());
+static_assert(!has_generator_static_local<empty_backend>());
