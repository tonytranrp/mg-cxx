diff --git a/clang/lib/AST/Expr.cpp b/clang/lib/AST/Expr.cpp
index d62de57f5859..24698fc0ec67 100644
--- a/clang/lib/AST/Expr.cpp
+++ b/clang/lib/AST/Expr.cpp
@@ -43,20 +43,35 @@
 #include <optional>
 using namespace clang;
 
+static ExprDependence
+computeCXXMGTypeCheckExprDependence(CXXMGTypeExprNode *ExprNode) {
+  ExprDependence D = ExprDependence::None;
+
+  if (!ExprNode)
+    return D;
+
+  if (ExprNode->containsUnexpandedParameterPack())
+    D |= ExprDependence::UnexpandedPack;
+
+  if (ExprNode->isDependent() || ExprNode->isInstantiationDependent())
+    D |= ExprDependence::ValueInstantiation;
+
+  return D;
+}
+
 CXXMGTypeCheckExpr *CXXMGTypeCheckExpr::Create(ASTContext &Ctx,
                                                CXXMGTypeExprNode *ExprNode) {
-  ExprDependence D = ExprDependence::None;
-  if (ExprNode) {
-    if (ExprNode->isDependent())
-      D |= ExprDependence::Type;
-    if (ExprNode->isInstantiationDependent())
-      D |= ExprDependence::Instantiation;
-    if (ExprNode->containsUnexpandedParameterPack())
-      D |= ExprDependence::UnexpandedPack;
-    if (ExprNode->isDependent() || ExprNode->isInstantiationDependent())
-      D |= ExprDependence::Value;
-  }
-  return new (Ctx) CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode, D);
+  return new (Ctx)
+      CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode,
+                         computeCXXMGTypeCheckExprDependence(ExprNode));
+}
+
+CXXMGTypeCheckExpr *
+CXXMGTypeCheckExpr::CreateResolved(ASTContext &Ctx,
+                                   CXXMGTypeExprNode *ExprNode, bool Value) {
+  return new (Ctx)
+      CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode, ExprDependence::None,
+                         /*HasKnownValue=*/true, Value);
 }
 
