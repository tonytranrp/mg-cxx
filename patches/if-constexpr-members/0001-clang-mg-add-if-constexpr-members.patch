+Decl *TemplateDeclInstantiator::VisitCXXMGClassMemberIfDecl(
+    CXXMGClassMemberIfDecl *D) {
+
+  // Substitute template arguments into condition
+  ExprResult InstCond =
+      SemaRef.SubstExpr(D->getCond(), TemplateArgs);
+
+  if (InstCond.isInvalid())
+    return nullptr;
+
+  // Still dependent after substitution:
+  // preserve placeholder for later specialization stage.
+  if (InstCond.get()->isValueDependent()) {
+    auto *NewD = CXXMGClassMemberIfDecl::Create(
+        SemaRef.Context,
+        Owner,
+        D->getIfLoc(),
+        D->getConstexprLoc(),
+        InstCond.get(),
+        D->getElseLoc(),
+        D->getThenDecls(),
+        D->getElseDecls());
+
+    Owner->addDecl(NewD);
+    return NewD;
+  }
+
+  // Evaluate final condition
+  bool CondValue = false;
+  if (!InstCond.get()->EvaluateAsBooleanCondition(
+          CondValue,
+          SemaRef.Context))
+    return nullptr;
+
+  ArrayRef<Decl *> SelectedDecls =
+      CondValue
+          ? D->getThenDecls()
+          : D->getElseDecls();
+
+  Decl *Last = nullptr;
+
+  for (Decl *BranchD : SelectedDecls) {
+
+    Decl *InstD = Visit(BranchD);
+    if (!InstD)
+      return nullptr;
+
+    // Some visitors already insert into Owner.
+    // Avoid duplicate insertion / visibility crashes.
+    if (InstD->getDeclContext() != Owner) {
+      InstD->setDeclContext(Owner);
+      Owner->addDecl(InstD);
+    }
+
+    Last = InstD;
+  }
+
+  // Branch chosen and expanded.
+  // Do NOT keep original placeholder in final class.
+  return Last;
+}
