+Parser::DeclGroupPtrTy Parser::ParseCXXMGClassMemberIf(
+    AccessSpecifier &AS,
+    ParsedAttributes &AccessAttrs,
+    DeclSpec::TST TagType,
+    Decl *TagDecl) {
+
+  assert(Tok.is(tok::kw_if) && "expected 'if'");
+
+  SourceLocation IfLoc = ConsumeToken();
+
+  // require constexpr
+  if (!Tok.is(tok::kw_constexpr)) {
+    Diag(Tok.getLocation(), diag::err_expected) << tok::kw_constexpr;
+    SkipUntil(tok::semi, tok::r_brace, StopBeforeMatch);
+    return nullptr;
+  }
+
+  SourceLocation ConstexprLoc = ConsumeToken();
+
+  // parse condition
+  BalancedDelimiterTracker Parens(*this, tok::l_paren);
+  if (Parens.consumeOpen()) {
+    Diag(Tok.getLocation(), diag::err_expected) << tok::l_paren;
+    SkipUntil(tok::semi, tok::r_brace, StopBeforeMatch);
+    return nullptr;
+  }
+
+  EnterExpressionEvaluationContext ConstantEvaluated(
+      Actions,
+      Sema::ExpressionEvaluationContext::ConstantEvaluated);
+
+  ExprResult Cond = ParseConstantExpressionInExprEvalContext();
+  if (Cond.isInvalid()) {
+    SkipMalformedDecl();
+    return nullptr;
+  }
+
+  if (Parens.consumeClose())
+    return nullptr;
+
+  // create placeholder decl immediately
+  CXXMGClassMemberIfDecl *IfDecl =
+      Actions.ActOnStartCXXMGClassMemberIf(
+          getCurScope(),
+          IfLoc,
+          ConstexprLoc,
+          Cond.get());
+
+  auto ParseMemberBlock =
+      [&](SmallVectorImpl<Decl *> &Decls,
+          SourceLocation &OpenLoc,
+          SourceLocation &CloseLoc) -> bool {
+
+        BalancedDelimiterTracker Braces(*this, tok::l_brace);
+        if (Braces.consumeOpen()) {
+          Diag(Tok.getLocation(), diag::err_expected) << tok::l_brace;
+          return true;
+        }
+
+        OpenLoc = Braces.getOpenLocation();
+
+        AccessSpecifier SavedAS = AS;
+
+        // enable deferred member capture
+        bool OldDeferred = ParsingCXXMGDeferredMembers;
+        auto *OldList = DeferredCXXMGDecls;
+
+        ParsingCXXMGDeferredMembers = true;
+        DeferredCXXMGDecls = &Decls;
+
+        while (Tok.isNot(tok::r_brace) &&
+               Tok.isNot(tok::eof)) {
+
+          SourceLocation Before = Tok.getLocation();
+          tok::TokenKind BeforeKind = Tok.getKind();
+
+          ParseCXXClassMemberDeclarationWithPragmas(
+              AS,
+              AccessAttrs,
+              TagType,
+              TagDecl);
+
+          // progress guard
+          if (Tok.getLocation() == Before &&
+              Tok.getKind() == BeforeKind) {
+            Diag(Tok.getLocation(), diag::err_expected)
+                << "class member declaration";
+            ConsumeAnyToken();
+          }
+        }
+
+        // restore parser state
+        ParsingCXXMGDeferredMembers = OldDeferred;
+        DeferredCXXMGDecls = OldList;
+
+        if (Braces.consumeClose())
+          return true;
+
+        CloseLoc = Braces.getCloseLocation();
+
+        AS = SavedAS;
+        return false;
+      };
+
+  SmallVector<Decl *, 8> ThenDecls;
+  SmallVector<Decl *, 8> ElseDecls;
+
+  SourceLocation ThenOpen, ThenClose;
+  SourceLocation ElseLoc, ElseOpen, ElseClose;
+
+  // then branch
+  if (ParseMemberBlock(
+          ThenDecls,
+          ThenOpen,
+          ThenClose))
+    return nullptr;
+
+  // optional else branch
+  if (Tok.is(tok::kw_else)) {
+    ElseLoc = ConsumeToken();
+
+    if (ParseMemberBlock(
+            ElseDecls,
+            ElseOpen,
+            ElseClose))
+      return nullptr;
+  }
+
+  // store captured members onto placeholder node
+  IfDecl->setThenDecls(
+      Actions.getASTContext(),
+      ThenDecls);
+
+  IfDecl->setElseDecls(
+      Actions.getASTContext(),
+      ElseDecls);
+
+  return Actions.ConvertDeclToDeclGroup(IfDecl);
+}
+
 Parser::DeclGroupPtrTy Parser::ParseCXXClassMemberDeclarationWithPragmas(
     AccessSpecifier &AS, ParsedAttributes &AccessAttrs, DeclSpec::TST TagType,
     Decl *TagDecl) {
@@ -3486,7 +3626,16 @@ Parser::DeclGroupPtrTy Parser::ParseCXXClassMemberDeclarationWithPragmas(
       return nullptr;
     }
     ParsedTemplateInfo TemplateInfo;
-    return ParseCXXClassMemberDeclaration(AS, AccessAttrs, TemplateInfo);
+    DeclGroupPtrTy Group = ParseCXXClassMemberDeclaration(AS, AccessAttrs, TemplateInfo);
+
+    if (ParsingCXXMGDeferredMembers && Group && DeferredCXXMGDecls) {
+      for (Decl *D : Group.get())
+        DeferredCXXMGDecls->push_back(D);
+
+      return nullptr; // prevent immediate use
+    }
+
+    return Group;
   }
 }
 
