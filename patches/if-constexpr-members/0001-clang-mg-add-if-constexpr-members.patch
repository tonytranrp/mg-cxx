+class CXXMGClassMemberIfDecl final : public Decl, public DeclContext {
+  SourceLocation IfLoc;
+  SourceLocation ConstexprLoc;
+  SourceLocation ElseLoc;
+
+  Stmt *Cond = nullptr;
+
+  unsigned NumThenDecls = 0;
+  unsigned NumElseDecls = 0;
+
+  Decl **ThenDecls = nullptr;
+  Decl **ElseDecls = nullptr;
+
+  CXXMGClassMemberIfDecl(DeclContext *DC, SourceLocation IfLoc,
+                         SourceLocation ConstexprLoc, Expr *Cond,
+                         SourceLocation ElseLoc)
+      : Decl(Decl::CXXMGClassMemberIf, DC, IfLoc),
+        DeclContext(Decl::CXXMGClassMemberIf),
+        IfLoc(IfLoc),
+        ConstexprLoc(ConstexprLoc),
+        ElseLoc(ElseLoc),
+        Cond(Cond) {}
+
+public:
+  static CXXMGClassMemberIfDecl *
+  Create(ASTContext &C, DeclContext *DC, SourceLocation IfLoc,
+         SourceLocation ConstexprLoc, Expr *Cond, SourceLocation ElseLoc,
+         ArrayRef<Decl *> ThenDecls, ArrayRef<Decl *> ElseDecls) {
+    auto *D = new (C, DC)
+        CXXMGClassMemberIfDecl(DC, IfLoc, ConstexprLoc, Cond, ElseLoc);
+
+    D->setThenDecls(C, ThenDecls);
+    D->setElseDecls(C, ElseDecls);
+
+    return D;
+  }
+
+  static CXXMGClassMemberIfDecl *
+  CreateEmpty(ASTContext &C, DeclContext *DC, SourceLocation IfLoc,
+              SourceLocation ConstexprLoc, Expr *Cond,
+              SourceLocation ElseLoc) {
+    return new (C, DC)
+        CXXMGClassMemberIfDecl(DC, IfLoc, ConstexprLoc, Cond, ElseLoc);
+  }
+
+  void setThenDecls(ASTContext &C, ArrayRef<Decl *> Decls) {
+    NumThenDecls = Decls.size();
+
+    if (Decls.empty()) {
+      ThenDecls = nullptr;
+      return;
+    }
+
+    ThenDecls = new (C) Decl *[Decls.size()];
+    std::uninitialized_copy(Decls.begin(), Decls.end(), ThenDecls);
+  }
+
+  void setElseDecls(ASTContext &C, ArrayRef<Decl *> Decls) {
+    NumElseDecls = Decls.size();
+
+    if (Decls.empty()) {
+      ElseDecls = nullptr;
+      return;
+    }
+
+    ElseDecls = new (C) Decl *[Decls.size()];
+    std::uninitialized_copy(Decls.begin(), Decls.end(), ElseDecls);
+  }
+
+  Expr *getCond() const {
+    return cast_or_null<Expr>(Cond);
+  }
+
+  ArrayRef<Decl *> getThenDecls() const {
+    return ArrayRef<Decl *>(ThenDecls, NumThenDecls);
+  }
+
+  ArrayRef<Decl *> getElseDecls() const {
+    return ArrayRef<Decl *>(ElseDecls, NumElseDecls);
+  }
+
+  SourceLocation getIfLoc() const { return IfLoc; }
+  SourceLocation getConstexprLoc() const { return ConstexprLoc; }
+  SourceLocation getElseLoc() const { return ElseLoc; }
+
+  SourceRange getSourceRange() const {
+    if (ElseLoc.isValid())
+      return SourceRange(IfLoc, ElseLoc);
+    return SourceRange(IfLoc, IfLoc);
+  }
+
+  static bool classofKind(Kind K) {
+    return K == Decl::CXXMGClassMemberIf;
+  }
+
+  static bool classof(const Decl *D) {
+    return classofKind(D->getKind());
+  }
+};
