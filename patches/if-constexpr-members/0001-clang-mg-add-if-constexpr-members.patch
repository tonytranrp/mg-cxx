+  CXXMGClassMemberIfDecl *ActOnStartCXXMGClassMemberIf(
+    Scope *S,
+    SourceLocation IfLoc,
+    SourceLocation ConstexprLoc,
+    Expr *Cond,
+    SourceLocation ElseLoc = SourceLocation()) {
+    (void)S;
+
+    auto *D = CXXMGClassMemberIfDecl::CreateEmpty(
+        Context,
+        CurContext,
+        IfLoc,
+        ConstexprLoc,
+        Cond,
+        ElseLoc);
+
+    CurContext->addDecl(D);
+    return D;
+  }
+
+  std::optional<bool> EvaluateCXXMGClassMemberIfCondition(
+      SourceLocation IfLoc, Expr *Cond) {
+    if (!Cond)
+      return std::nullopt;
+
+    if (Cond->isValueDependent())
+      return std::nullopt;
+
+    bool CondValue = false;
+    if (!Cond->EvaluateAsBooleanCondition(CondValue, Context)) {
+      Diag(Cond->getExprLoc(),
+          diag::err_constexpr_if_condition_expression_is_not_constant);
+      return std::nullopt;
+    }
+
+    return CondValue;
+  }
+
+  using CXXMGClassMemberIfInstantiationCallbackTy =
+    std::function<void(CXXMGClassMemberIfDecl *, bool, DeclContext *)>;
+
+  CXXMGClassMemberIfInstantiationCallbackTy CXXMGClassMemberIfInstantiationCallback;
+
+  void InstantiateCXXMGClassMemberIf(
+      CXXMGClassMemberIfDecl *D, bool CondValue, DeclContext *Owner) {
+    if (!CXXMGClassMemberIfInstantiationCallback) {
+      Diag(D->getIfLoc(), diag::err_expected)
+          << "cannot instantiate class-scope if constexpr without parser callback";
+      return;
+    }
+
+    CXXMGClassMemberIfInstantiationCallback(D, CondValue, Owner);
+  }
+
+  // ActOnCXXMGClassMemberIf
+  Decl *ActOnCXXMGClassMemberIf(
+      Scope *S,
+      SourceLocation IfLoc,
+      SourceLocation ConstexprLoc,
+      Expr *Cond,
+      SourceLocation ThenOpenLoc,
+      SourceLocation ThenCloseLoc,
+      ArrayRef<Decl *> ThenDecls,
+      SourceLocation ElseLoc,
+      SourceLocation ElseOpenLoc,
+      SourceLocation ElseCloseLoc,
+      ArrayRef<Decl *> ElseDecls) {
+    (void)S;
+    (void)ThenOpenLoc;
+    (void)ThenCloseLoc;
+    (void)ElseOpenLoc;
+    (void)ElseCloseLoc;
+
+    Decl *D = CXXMGClassMemberIfDecl::Create(
+        Context, CurContext, IfLoc, ConstexprLoc, Cond,
+        ElseLoc, ThenDecls, ElseDecls);
+
+    CurContext->addDecl(D);
+    return D;
+  }
