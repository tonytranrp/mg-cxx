+// RUN: %clang_cc1 -std=c++mg -fsyntax-only -verify %s
+
+struct S {
+  static constexpr bool cond = true;
+  if constexpr (cond) {
+    int a;
+  } else {
+    int b;
+  }
+};
+
+void testS() {
+  S s;
+  s.a = 1;
+  //s.b = 2; // expected-error {{no member named 'b' in 'S'}}
+}
+
+struct T {
+  static constexpr bool cond = false;
+  if constexpr (cond) {
+    int a;
+  } else {
+    int b;
+  }
+};
+
+void testT() {
+  T t;
+  t.b = 1;
+  //t.a = 2; // expected-error {{no member named 'a' in 'T'}}
+}
+
+static_assert(sizeof(S) == sizeof(int));
+static_assert(sizeof(T) == sizeof(int));
