+void Preprocessor::HandleUrlIncludeDirective(SourceLocation HashLoc,
+                                             Token &IncludeTok) {
+  if (!PPOpts.EnableUrlInclude) {
+    Diag(IncludeTok, diag::err_pp_urlinclude_disabled);
+    DiscardUntilEndOfDirective();
+    return;
+  }
+
+  Token FilenameTok;
+  if (LexHeaderName(FilenameTok))
+    return;
+
+  if (FilenameTok.isNot(tok::header_name)) {
+    Diag(FilenameTok.getLocation(), diag::err_pp_expects_filename);
+    if (FilenameTok.isNot(tok::eod))
+      DiscardUntilEndOfDirective();
+    return;
+  }
+
+  SourceLocation EndLoc = CheckEndOfDirective("urlinclude", true);
+  (void)EndLoc;
+
+  SmallString<256> SpellingBuffer;
+  StringRef URL = getSpelling(FilenameTok, SpellingBuffer);
+  SourceLocation CharEnd = FilenameTok.getEndLoc();
+  CharSourceRange FilenameRange =
+      CharSourceRange::getCharRange(FilenameTok.getLocation(), CharEnd);
+  bool IsAngled = GetIncludeFilenameSpelling(FilenameTok.getLocation(), URL);
+  if (URL.empty())
+    return;
+
+  UrlIncludeResult Result;
+  if (!ensureUrlIncludeCached(*this, URL, FilenameTok.getLocation(), Result))
+    return;
+
+  OptionalFileEntryRef File = FileMgr.getOptionalFileRef(Result.CachePath);
+  if (!File) {
+    Diag(FilenameTok.getLocation(), diag::err_pp_urlinclude_cache_file_missing)
+        << Result.CachePath;
+    return;
+  }
+
+  enum { Enter, Skip, IncludeLimitReached } Action = Enter;
+  if (PPOpts.SingleFileParseMode)
+    Action = IncludeLimitReached;
+
+  if (Action == Enter && HasReachedMaxIncludeDepth && alreadyIncluded(*File))
+    Action = IncludeLimitReached;
+
+  bool IsFirstIncludeOfFile = false;
+  if (Action == Enter &&
+      !HeaderInfo.ShouldEnterIncludeFile(*this, *File, /*isImport=*/false,
+                                         getLangOpts().Modules,
+                                         /*M=*/nullptr,
+                                         IsFirstIncludeOfFile))
+    Action = Skip;
+
+  SrcMgr::CharacteristicKind FileCharacter = SrcMgr::C_User;
+
+  if (Callbacks) {
+    Callbacks->InclusionDirective(
+        HashLoc, IncludeTok, URL, IsAngled, FilenameRange, File,
+        Result.SearchPath, Result.RelativePath, /*Imported=*/nullptr,
+        /*ModuleImported=*/false, FileCharacter);
+    if (Action == Skip)
+      Callbacks->FileSkipped(*File, FilenameTok, FileCharacter);
+  }
+
+  if (Action != Enter)
+    return;
+
+  if (IncludeMacroStack.size() == MaxAllowedIncludeStackDepth - 1) {
+    Diag(FilenameTok, diag::err_pp_include_too_deep);
+    HasReachedMaxIncludeDepth = true;
+    return;
+  }
+
+  SourceLocation IncludePos = FilenameTok.getLocation();
+  if (IncludePos.isMacroID())
+    IncludePos = SourceMgr.getExpansionRange(IncludePos).getEnd();
+  FileID FID = SourceMgr.createFileID(*File, IncludePos, FileCharacter);
+  if (!FID.isValid()) {
+    TheModuleLoader.HadFatalFailure = true;
+    IncludeTok.setKind(tok::eof);
+    CurLexer->cutOffLexing();
+    return;
+  }
+
+  EnterSourceFile(FID, nullptr, FilenameTok.getLocation(),
+                  IsFirstIncludeOfFile);
+}
