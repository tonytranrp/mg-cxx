diff --git a/clang/lib/AST/CXXMGTypeExpr.cpp b/clang/lib/AST/CXXMGTypeExpr.cpp
index eb65f560f88d..7777373898de 100644
--- a/clang/lib/AST/CXXMGTypeExpr.cpp
+++ b/clang/lib/AST/CXXMGTypeExpr.cpp
@@ -26,6 +26,31 @@ const char *clang::getCXXMGTypeExprOpcodeSpelling(CXXMGTypeExprOpcode Op) {
   llvm_unreachable("unknown C++MG type-expression opcode");
 }
 
+bool clang::isSameCXXMGTypeExprNode(const ASTContext &Ctx,
+                                    const CXXMGTypeExprNode *A,
+                                    const CXXMGTypeExprNode *B) {
+  if (A == B)
+    return true;
+  if (!A || !B || A->getKind() != B->getKind())
+    return false;
+
+  switch (A->getKind()) {
+  case CXXMGTypeExprNode::Operand: {
+    TypeSourceInfo *ATSI = A->getOperandTypeSourceInfo();
+    TypeSourceInfo *BTSI = B->getOperandTypeSourceInfo();
+    if (!ATSI || !BTSI)
+      return ATSI == BTSI;
+    return ASTContext::hasSameType(ATSI->getType(), BTSI->getType());
+  }
+  case CXXMGTypeExprNode::Binary:
+    return A->getOpcode() == B->getOpcode() &&
+           isSameCXXMGTypeExprNode(Ctx, A->getLHS(), B->getLHS()) &&
+           isSameCXXMGTypeExprNode(Ctx, A->getRHS(), B->getRHS());
+  }
+
+  llvm_unreachable("unknown C++MG type-expression node kind");
+}
+
 CXXMGTypeExprNode::CXXMGTypeExprNode(
     TypeSourceInfo *OperandTSI, SourceRange Range, bool Dependent,
     bool InstantiationDependent, bool ContainsUnexpandedParameterPack)
