From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mike <michaelgorney4@gmail.com>
Date: Mon, 8 Jun 2026 22:46:03 -0400
Subject: [PATCH 7/7] clang-mg: update traits


diff --git a/clang/lib/Parse/ParseCXXMGTraitExpr.cpp b/clang/lib/Parse/ParseCXXMGTraitExpr.cpp
index 883df3239e37..92a89ed93020 100644
--- a/clang/lib/Parse/ParseCXXMGTraitExpr.cpp
+++ b/clang/lib/Parse/ParseCXXMGTraitExpr.cpp
@@ -24,6 +24,23 @@ static bool mayStartQualifiedCXXMGImplementsExpression(Parser &P) {
   if (!P.GetLookAheadToken(I).is(tok::identifier))
     return false;
   ++I;
+
+  if (P.GetLookAheadToken(I).is(tok::less)) {
+    unsigned Depth = 0;
+    do {
+      if (P.GetLookAheadToken(I).is(tok::less))
+        ++Depth;
+      else if (P.GetLookAheadToken(I).is(tok::greater)) {
+        if (Depth == 0)
+          return false;
+        --Depth;
+      } else if (P.GetLookAheadToken(I).is(tok::eof)) {
+        return false;
+      }
+      ++I;
+    } while (Depth != 0);
+  }
+
   while (P.GetLookAheadToken(I).is(tok::coloncolon) &&
          P.GetLookAheadToken(I + 1).is(tok::identifier))
     I += 2;
diff --git a/clang/lib/Sema/SemaCXXMGTraitExpr.cpp b/clang/lib/Sema/SemaCXXMGTraitExpr.cpp
index cfba2c41a15d..d02e55e9e452 100644
--- a/clang/lib/Sema/SemaCXXMGTraitExpr.cpp
+++ b/clang/lib/Sema/SemaCXXMGTraitExpr.cpp
@@ -134,6 +134,20 @@ resolveImplementsOperand(Sema &S, TypeSourceInfo *TSI, SourceLocation Loc,
       S.Diag(Loc, diag::err_cxxmg_implements_union_operand) << QT;
     return nullptr;
   }
+  // `implements` structurally inspects record members. For class template
+  // specializations such as `Test<true>`, the specialization can be named
+  // before its definition has been instantiated. Force completion before
+  // checking `hasDefinition()` or iterating over `decls()`.
+  if (!RD->isCompleteDefinition()) {
+    if (S.RequireCompleteType(Loc, QT,
+                              diag::err_cxxmg_implements_incomplete_operand))
+      return nullptr;
+
+    RD = QT.getDesugaredType(S.Context)->getAsCXXRecordDecl();
+    if (!RD)
+      return nullptr;
+  }
+
   if (!RD->hasDefinition()) {
     if (Diagnose)
       S.Diag(Loc, diag::err_cxxmg_implements_incomplete_operand) << QT;
diff --git a/clang/test/CXXMG/traits/trait-implements-dependent-template-specialization.cpp b/clang/test/CXXMG/traits/trait-implements-dependent-template-specialization.cpp
new file mode 100644
index 000000000000..f89901e2cd37
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-dependent-template-specialization.cpp
@@ -0,0 +1,27 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+template<bool Val>
+struct Test {
+  int t = 0;
+  int v = 0;
+};
+
+trait ValTrait {
+  int v;
+};
+
+template<bool B>
+constexpr bool has_v_keyword() {
+  return Test<B> implements ValTrait;
+}
+
+template<bool B>
+constexpr bool has_v_angle() {
+  return Test<B> <> ValTrait;
+}
+
+static_assert(has_v_keyword<true>());
+static_assert(has_v_keyword<false>());
+static_assert(has_v_angle<true>());
+static_assert(has_v_angle<false>());
diff --git a/clang/test/CXXMG/traits/trait-implements-incomplete.cpp b/clang/test/CXXMG/traits/trait-implements-incomplete.cpp
new file mode 100644
index 000000000000..3e3090beafc7
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-incomplete.cpp
@@ -0,0 +1,11 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+struct Incomplete;
+// expected-note@-1 {{forward declaration of 'Incomplete'}}
+
+trait ValTrait {
+  int v;
+};
+
+static_assert(Incomplete implements ValTrait);
+// expected-error@-1 {{C++MG 'implements' operand 'Incomplete' is incomplete}}
diff --git a/clang/test/CXXMG/traits/trait-implements-template-specialization.cpp b/clang/test/CXXMG/traits/trait-implements-template-specialization.cpp
new file mode 100644
index 000000000000..b66a717b64ce
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-template-specialization.cpp
@@ -0,0 +1,39 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+template<bool Val>
+struct Test {
+  int t = 0;
+  int v = 0;
+};
+
+trait ValTrait {
+  int v;
+};
+
+static_assert(Test<true> implements ValTrait);
+static_assert(Test<false> implements ValTrait);
+
+static_assert(Test<true> <> ValTrait);
+static_assert(Test<false> <> ValTrait);
+
+template<class T>
+struct Box {
+  T value;
+};
+
+trait IntValueTrait {
+  int value;
+};
+
+trait BoolValueTrait {
+  bool value;
+};
+
+static_assert(Box<int> implements IntValueTrait);
+static_assert(!(Box<int> implements BoolValueTrait));
+static_assert(Box<bool> implements BoolValueTrait);
+
+static_assert(Box<int> <> IntValueTrait);
+static_assert(!(Box<int> <> BoolValueTrait));
+static_assert(Box<bool> <> BoolValueTrait);
-- 
