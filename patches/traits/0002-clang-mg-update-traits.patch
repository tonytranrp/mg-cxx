diff --git a/clang/lib/Sema/SemaDeclCXXMG.cpp b/clang/lib/Sema/SemaDeclCXXMG.cpp
new file mode 100644
index 000000000000..9105920532e6
--- /dev/null
+++ b/clang/lib/Sema/SemaDeclCXXMG.cpp
@@ -0,0 +1,149 @@
+//===------ SemaDeclCXXMG.cpp - Semantic Analysis for C++MG Declarations ------===//
+//
+//  This file implements semantic analysis for C++MG declarations.
+//
+//===----------------------------------------------------------------------===//
+
+using namespace clang;
+
+namespace {
+void Sema::BeginCXXMGConditionalMemberArm(CXXRecordDecl *TargetRecord,
+                                          AccessSpecifier AS) {
+  assert(TargetRecord && "conditional member arm needs a target record");
+
+  CXXMGConditionalMemberArmState State;
+  State.TargetRecord = TargetRecord;
+  State.StartAS = AS;
+  CXXMGConditionalMemberArmStack.push_back(std::move(State));
+}
+
+void Sema::EndCXXMGConditionalMemberArm(
+    llvm::SmallVectorImpl<Decl *> &OutPatternDecls) {
+  assert(!CXXMGConditionalMemberArmStack.empty() &&
+         "ending conditional member arm without active state");
+
+  CXXMGConditionalMemberArmState &State =
+      CXXMGConditionalMemberArmStack.back();
+  OutPatternDecls.append(State.PatternDecls.begin(), State.PatternDecls.end());
+  CXXMGConditionalMemberArmStack.pop_back();
+}
+
+bool Sema::isCollectingCXXMGConditionalMemberForCurrentContext() const {
+  return !CXXMGConditionalMemberArmStack.empty() &&
+         CXXMGConditionalMemberArmStack.back().TargetRecord == CurContext;
+}
+
+void Sema::AddCXXMGConditionalMemberPatternDecl(Decl *D) {
+  assert(D && "cannot collect a null conditional member pattern declaration");
+  assert(isCollectingCXXMGConditionalMemberForCurrentContext() &&
+         "collecting a conditional member pattern from the wrong context");
+  CXXMGConditionalMemberArmStack.back().PatternDecls.push_back(D);
+}
+
+Decl *Sema::ActOnCXXMGConditionalMember(
+    Scope *S, Decl *TagDecl, SourceLocation IfLoc,
+    llvm::ArrayRef<CXXMGConditionalMemberArm> Arms) {
+  CXXRecordDecl *Record = dyn_cast_or_null<CXXRecordDecl>(TagDecl);
+  if (!Record)
+    if (auto *Template = dyn_cast_or_null<ClassTemplateDecl>(TagDecl))
+      Record = Template->getTemplatedDecl();
+  if (!Record)
+    return nullptr;
+
+  auto *D = CXXMGConditionalMemberDecl::Create(Context, Record, IfLoc, Arms);
+  Record->addDecl(D);
+
+  for (const CXXMGConditionalMemberArm &Arm : D->arms()) {
+    bool Selected = Arm.isElseArm();
+    if (Arm.hasCondition()) {
+      if (Arm.Condition->isValueDependent())
+        break;
+
+      bool ConditionValue = false;
+      if (!Arm.Condition->EvaluateAsBooleanCondition(ConditionValue, Context))
+        continue;
+
+      Selected = ConditionValue;
+    }
+
+    if (!Selected)
+      continue;
+
+    for (Decl *Pattern : Arm.Decls) {
+      Record->addDecl(Pattern);
+      if (auto *BUD = dyn_cast<BaseUsingDecl>(Pattern))
+        for (UsingShadowDecl *Shadow : BUD->shadows())
+          Record->addDecl(Shadow);
+      if (auto *FD = dyn_cast<FieldDecl>(Pattern))
+        FieldCollector->Add(FD);
+    }
+    break;
+  }
+
+  return D;
+}
+
+Decl *Sema::ActOnCXXMGTraitAssociatedTypeRequirement(
+    Scope *S, Decl *TraitDecl, SourceLocation UsingLoc, SourceLocation NameLoc,
+    IdentifierInfo *Name) {
+  auto *Record = dyn_cast_or_null<CXXRecordDecl>(TraitDecl);
+  if (!Record || !Record->isTrait())
+    return nullptr;
+  auto *D = TraitRequirementDecl::Create(
+      Context, Record, UsingLoc, NameLoc, Name,
+      TraitRequirementDecl::AssociatedTypeAny, nullptr);
+  Record->addDecl(D);
+  return D;
+}
+
+Decl *Sema::ActOnCXXMGTraitStaticFunctionRequirement(
+    Scope *S, Decl *TraitDecl, SourceLocation StaticLoc, SourceLocation NameLoc,
+    IdentifierInfo *Name, TypeSourceInfo *FunctionTypeInfo) {
+  auto *Record = dyn_cast_or_null<CXXRecordDecl>(TraitDecl);
+  if (!Record || !Record->isTrait())
+    return nullptr;
+  auto *D = TraitRequirementDecl::Create(
+      Context, Record, StaticLoc, NameLoc, Name,
+      TraitRequirementDecl::StaticFunctionAnyReturn, FunctionTypeInfo);
+  Record->addDecl(D);
+  return D;
+}
+
+void Sema::ActOnCXXMGTraitMemberDeclaration(Decl *TraitDecl,
+                                            DeclGroupPtrTy DG) {
+  auto *Record = dyn_cast_or_null<CXXRecordDecl>(TraitDecl);
+  if (!Record || !Record->isTrait() || !DG)
+    return;
+
+  for (Decl *D : DG.get()) {
+    if (!D)
+      continue;
+    if (auto *FD = dyn_cast<FieldDecl>(D)) {
+      if (!FD->getIdentifier() || FD->isBitField())
+        Diag(FD->getLocation(), diag::err_cxxmg_trait_invalid_member);
+      if (FD->hasInClassInitializer())
+        Diag(FD->getLocation(), diag::err_cxxmg_trait_initializer);
+      continue;
+    }
+    if (auto *VD = dyn_cast<VarDecl>(D)) {
+      if (!VD->isStaticDataMember())
+        Diag(VD->getLocation(), diag::err_cxxmg_trait_invalid_member);
+      if (VD->hasInit())
+        Diag(VD->getLocation(), diag::err_cxxmg_trait_initializer);
+      continue;
+    }
+    if (isa<TypeAliasDecl>(D) || isa<TraitRequirementDecl>(D))
+      continue;
+    if (auto *MD = dyn_cast<CXXMethodDecl>(D)) {
+      if (isa<CXXConstructorDecl>(MD) || isa<CXXDestructorDecl>(MD) ||
+          isa<CXXConversionDecl>(MD) ||
+          MD->getDeclName().getNameKind() == DeclarationName::CXXOperatorName)
+        Diag(MD->getLocation(), diag::err_cxxmg_trait_special_member);
+      if (MD->doesThisDeclarationHaveABody())
+        Diag(MD->getLocation(), diag::err_cxxmg_trait_function_body);
+      continue;
+    }
+    Diag(D->getLocation(), diag::err_cxxmg_trait_invalid_member);
+  }
+}
+}
