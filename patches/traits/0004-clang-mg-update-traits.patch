From: Mike <michaelgorney4@gmail.com>
Date: Mon, 8 Jun 2026 12:37:57 -0400
Subject: [PATCH 4/7] clang-mg: update traits


diff --git a/clang/lib/Parse/ParseDeclCXXMG.cpp b/clang/lib/Parse/ParseDeclCXXMG.cpp
index 20cd1d4a1d42..52eff5ac6c93 100644
--- a/clang/lib/Parse/ParseDeclCXXMG.cpp
+++ b/clang/lib/Parse/ParseDeclCXXMG.cpp
@@ -132,3 +132,67 @@ SourceRange Parser::ParseCXXMGConditionalMemberBody(AccessSpecifier &AS,
     RBraceLoc = ConsumeBrace();
   return SourceRange(LBraceLoc, RBraceLoc);
 }
+
+using namespace clang;
+
+Parser::DeclGroupPtrTy Parser::ParseCXXMGTraitMemberDeclaration(
+    AccessSpecifier &AS, ParsedAttributes &AccessAttrs, Decl *TagDecl) {
+  if (Tok.isOneOf(tok::kw_private, tok::kw_public, tok::kw_protected) &&
+      NextToken().is(tok::colon)) {
+    Diag(Tok.getLocation(), diag::err_cxxmg_trait_access_specifier);
+    ConsumeToken();
+    ConsumeToken();
+    return nullptr;
+  }
+
+  if (Tok.is(tok::kw_using) && NextToken().is(tok::identifier) &&
+      GetLookAheadToken(2).is(tok::semi)) {
+    SourceLocation UsingLoc = ConsumeToken();
+    SourceLocation NameLoc = Tok.getLocation();
+    IdentifierInfo *Name = Tok.getIdentifierInfo();
+    ConsumeToken();
+    ConsumeToken();
+    Decl *D = Actions.ActOnCXXMGTraitAssociatedTypeRequirement(
+        getCurScope(), TagDecl, UsingLoc, NameLoc, Name);
+    return DeclGroupPtrTy::make(DeclGroupRef(D));
+  }
+
+  if (Tok.is(tok::kw_static) && NextToken().is(tok::identifier) &&
+      GetLookAheadToken(2).is(tok::l_paren)) {
+    SourceLocation StaticLoc = ConsumeToken();
+    SourceLocation NameLoc = Tok.getLocation();
+    IdentifierInfo *Name = Tok.getIdentifierInfo();
+    ConsumeToken();
+    BalancedDelimiterTracker T(*this, tok::l_paren);
+    T.consumeOpen();
+    if (Tok.isNot(tok::r_paren))
+      SkipUntil(tok::r_paren, StopBeforeMatch);
+    T.consumeClose();
+    ExpectAndConsume(tok::semi);
+    Decl *D = Actions.ActOnCXXMGTraitStaticFunctionRequirement(
+        getCurScope(), TagDecl, StaticLoc, NameLoc, Name, nullptr);
+    return DeclGroupPtrTy::make(DeclGroupRef(D));
+  }
+
+  tok::TokenKind PrevKind = tok::unknown;
+  for (unsigned I = 0; Tok.isNot(tok::eof); ++I) {
+    const Token &Lookahead = GetLookAheadToken(I);
+    if (Lookahead.isOneOf(tok::semi, tok::r_brace))
+      break;
+    if (Lookahead.is(tok::l_brace) && PrevKind == tok::r_paren) {
+      Diag(Lookahead.getLocation(), diag::err_cxxmg_trait_function_body);
+      for (unsigned J = 0; J < I; ++J)
+        ConsumeAnyToken();
+      ConsumeBrace();
+      SkipUntil(tok::r_brace);
+      TryConsumeToken(tok::semi);
+      return nullptr;
+    }
+    PrevKind = Lookahead.getKind();
+  }
+
+  DeclGroupPtrTy DG = ParseCXXClassMemberDeclarationWithPragmas(
+      AS, AccessAttrs, DeclSpec::TST_trait, TagDecl);
+  Actions.ActOnCXXMGTraitMemberDeclaration(TagDecl, DG);
+  return DG;
+}
