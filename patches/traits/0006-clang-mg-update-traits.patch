index 000000000000..36d0ccd662a4
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-dependent.cpp
@@ -0,0 +1,32 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+trait HasGenerate {
+  void generate();
+};
+
+struct Graphviz {
+  void generate();
+};
+
+struct Empty {};
+
+template <typename T>
+constexpr bool has_generate_keyword() {
+  using type_t = T;
+  constexpr bool result = type_t implements HasGenerate;
+  return result;
+}
+
+template <typename T>
+constexpr bool has_generate_shorthand() {
+  using type_t = T;
+  constexpr bool result = type_t <> HasGenerate;
+  return result;
+}
+
+static_assert(has_generate_keyword<Graphviz>());
+static_assert(!has_generate_keyword<Empty>());
+
+static_assert(has_generate_shorthand<Graphviz>());
+static_assert(!has_generate_shorthand<Empty>());
