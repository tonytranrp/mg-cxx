diff --git a/clang/test/CXXMG/traits/trait-implements-basic.cpp b/clang/test/CXXMG/traits/trait-implements-basic.cpp
new file mode 100644
index 000000000000..9dd50912770d
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-basic.cpp
@@ -0,0 +1,18 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+trait HasValue {
+  int value;
+};
+
+struct S {
+  int value;
+};
+
+struct Empty {};
+
+static_assert(S implements HasValue);
+static_assert(S <> HasValue);
+
+static_assert(!(Empty implements HasValue));
+static_assert(!(Empty <> HasValue));
diff --git a/clang/test/CXXMG/traits/trait-implements-dependent.cpp b/clang/test/CXXMG/traits/trait-implements-dependent.cpp
