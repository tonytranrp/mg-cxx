diff --git a/clang/lib/Sema/SemaCXXMGTraitExpr.cpp b/clang/lib/Sema/SemaCXXMGTraitExpr.cpp
new file mode 100644
index 000000000000..cfba2c41a15d
--- /dev/null
+++ b/clang/lib/Sema/SemaCXXMGTraitExpr.cpp
@@ -0,0 +1,286 @@
+//===------ SemaCXXMGTraitExpr.cpp - C++MG Trait Expressions --------------===//
+
+#include "clang/Sema/SemaInternal.h"
+
+#include "clang/AST/ASTContext.h"
+#include "clang/AST/DeclCXX.h"
+#include "clang/AST/ExprCXX.h"
+#include "clang/AST/ExprCXXMG.h"
+#include "clang/Basic/DiagnosticSema.h"
+#include "llvm/ADT/STLExtras.h"
+#include "llvm/Support/Casting.h"
+
+using namespace clang;
+
+namespace {
+
+enum class CXXMGTraitMemberKind {
+  Field,
+  StaticData,
+  InstanceMethod,
+  StaticMethod,
+  TypeAliasExact,
+  AssociatedTypeAny,
+  StaticFunctionAnyReturn
+};
+
+struct CXXMGTraitMemberDescriptor {
+  CXXMGTraitMemberKind Kind;
+  DeclarationName Name;
+  SourceLocation Loc;
+  NamedDecl *SourceDecl = nullptr;
+  QualType ValueType;
+  QualType FunctionType;
+  TypeSourceInfo *FunctionTypeInfo = nullptr;
+};
+
+struct CXXMGTraitMemberSet {
+  SmallVector<CXXMGTraitMemberDescriptor, 16> Members;
+  bool Invalid = false;
+};
+
+static bool sameValueType(ASTContext &Ctx, QualType A, QualType B) {
+  return !A.isNull() && !B.isNull() &&
+         Ctx.hasSameType(A.getCanonicalType(), B.getCanonicalType());
+}
+
+static const FunctionProtoType *getProto(QualType T) {
+  return T.isNull() ? nullptr : T->getAs<FunctionProtoType>();
+}
+
+static bool sameFunctionSignature(ASTContext &Ctx,
+                                  const CXXMGTraitMemberDescriptor &A,
+                                  const CXXMGTraitMemberDescriptor &B,
+                                  bool IgnoreReturnType) {
+  const auto *AP = getProto(A.FunctionType);
+  const auto *BP = getProto(B.FunctionType);
+  if (!AP || !BP)
+    return false;
+  if (!IgnoreReturnType &&
+      !Ctx.hasSameType(AP->getReturnType().getCanonicalType(),
+                       BP->getReturnType().getCanonicalType()))
+    return false;
+  if (AP->getNumParams() != BP->getNumParams())
+    return false;
+  if (AP->getMethodQuals() != BP->getMethodQuals() ||
+      AP->getRefQualifier() != BP->getRefQualifier())
+    return false;
+  for (unsigned I = 0, E = AP->getNumParams(); I != E; ++I)
+    if (!Ctx.hasSameType(AP->getParamType(I).getCanonicalType(),
+                         BP->getParamType(I).getCanonicalType()))
+      return false;
+  return true;
+}
+
+static bool memberMatches(ASTContext &Ctx,
+                          const CXXMGTraitMemberDescriptor &Req,
+                          const CXXMGTraitMemberDescriptor &Cand) {
+  if (Req.Name != Cand.Name)
+    return false;
+  if (Req.Kind == CXXMGTraitMemberKind::AssociatedTypeAny)
+    return Cand.Kind == CXXMGTraitMemberKind::AssociatedTypeAny ||
+           Cand.Kind == CXXMGTraitMemberKind::TypeAliasExact;
+  if (Req.Kind == CXXMGTraitMemberKind::StaticFunctionAnyReturn)
+    return Cand.Kind == CXXMGTraitMemberKind::StaticMethod &&
+           sameFunctionSignature(Ctx, Req, Cand, /*IgnoreReturnType=*/true);
+  if (Req.Kind != Cand.Kind)
+    return false;
+  switch (Req.Kind) {
+  case CXXMGTraitMemberKind::Field:
+  case CXXMGTraitMemberKind::StaticData:
+  case CXXMGTraitMemberKind::TypeAliasExact:
+    return sameValueType(Ctx, Req.ValueType, Cand.ValueType);
+  case CXXMGTraitMemberKind::InstanceMethod:
+  case CXXMGTraitMemberKind::StaticMethod:
+    return sameFunctionSignature(Ctx, Req, Cand, /*IgnoreReturnType=*/false);
+  case CXXMGTraitMemberKind::AssociatedTypeAny:
+  case CXXMGTraitMemberKind::StaticFunctionAnyReturn:
+    llvm_unreachable("handled above");
+  }
+  llvm_unreachable("unknown C++MG trait member kind");
+}
+
+static CXXRecordDecl *
+resolveImplementsOperand(Sema &S, TypeSourceInfo *TSI, SourceLocation Loc,
+                         bool RequirementSide, bool Diagnose) {
+  if (!TSI) {
+    if (Diagnose)
+      S.Diag(Loc, RequirementSide ? diag::err_cxxmg_implements_rhs_not_trait
+                                  : diag::err_cxxmg_implements_lhs_not_type);
+    return nullptr;
+  }
+  QualType QT = TSI->getType();
+  if (QT.isNull())
+    return nullptr;
+  if (QT->isDependentType() || QT->isInstantiationDependentType())
+    return nullptr;
+  if (QT->isReferenceType() || QT->isPointerType() || QT->isArrayType() ||
+      QT->isFunctionType()) {
+    if (Diagnose)
+      S.Diag(Loc, RequirementSide ? diag::err_cxxmg_implements_rhs_not_trait
+                                  : diag::err_cxxmg_implements_lhs_not_type);
+    return nullptr;
+  }
+  QT = QT.getUnqualifiedType();
+  CXXRecordDecl *RD = QT.getDesugaredType(S.Context)->getAsCXXRecordDecl();
+  if (!RD) {
+    if (Diagnose)
+      S.Diag(Loc, RequirementSide ? diag::err_cxxmg_implements_rhs_not_trait
+                                  : diag::err_cxxmg_implements_lhs_not_type);
+    return nullptr;
+  }
+  if (RD->isUnion()) {
+    if (Diagnose)
+      S.Diag(Loc, diag::err_cxxmg_implements_union_operand) << QT;
+    return nullptr;
+  }
+  if (!RD->hasDefinition()) {
+    if (Diagnose)
+      S.Diag(Loc, diag::err_cxxmg_implements_incomplete_operand) << QT;
+    return nullptr;
+  }
+  RD = RD->getDefinitionOrSelf();
+  if (RequirementSide && !RD->isTrait()) {
+    if (Diagnose)
+      S.Diag(Loc, diag::err_cxxmg_implements_rhs_not_trait);
+    return nullptr;
+  }
+  if (RD->isInvalidDecl())
+    return nullptr;
+  return RD;
+}
+
+static bool collectMembers(Sema &S, CXXRecordDecl *RD,
+                           SmallVectorImpl<CXXMGTraitMemberDescriptor> &Out) {
+  ASTContext &Ctx = S.Context;
+  bool Invalid = false;
+  for (Decl *D : RD->decls()) {
+    if (auto *FD = dyn_cast<FieldDecl>(D)) {
+      if (!FD->getDeclName() || FD->isBitField()) {
+        Invalid = true;
+        continue;
+      }
+      Out.push_back({CXXMGTraitMemberKind::Field, FD->getDeclName(),
+                     FD->getLocation(), FD, FD->getType(), QualType(),
+                     nullptr});
+      continue;
+    }
+    if (auto *VD = dyn_cast<VarDecl>(D)) {
+      if (!VD->isStaticDataMember())
+        continue;
+      Out.push_back({CXXMGTraitMemberKind::StaticData, VD->getDeclName(),
+                     VD->getLocation(), VD, VD->getType(), QualType(),
+                     nullptr});
+      continue;
+    }
+    if (auto *TD = dyn_cast<TypedefNameDecl>(D)) {
+      Out.push_back({CXXMGTraitMemberKind::TypeAliasExact, TD->getDeclName(),
+                     TD->getLocation(), TD, TD->getUnderlyingType(),
+                     QualType(), nullptr});
+      continue;
+    }
+    if (auto *TR = dyn_cast<TraitRequirementDecl>(D)) {
+      CXXMGTraitMemberDescriptor M;
+      M.Kind = TR->isAssociatedTypeAny()
+                   ? CXXMGTraitMemberKind::AssociatedTypeAny
+                   : CXXMGTraitMemberKind::StaticFunctionAnyReturn;
+      M.Name = TR->getDeclName();
+      M.Loc = TR->getLocation();
+      M.SourceDecl = TR;
+      M.FunctionTypeInfo = TR->getFunctionTypeInfo();
+      if (M.FunctionTypeInfo)
+        M.FunctionType = M.FunctionTypeInfo->getType();
+      else if (TR->isStaticFunctionAnyReturn())
+        M.FunctionType =
+            Ctx.getFunctionType(Ctx.VoidTy, {}, FunctionProtoType::ExtProtoInfo());
+      Out.push_back(M);
+      continue;
+    }
+    if (auto *MD = dyn_cast<CXXMethodDecl>(D)) {
+      if (isa<CXXConstructorDecl>(MD) || isa<CXXDestructorDecl>(MD) ||
+          isa<CXXConversionDecl>(MD) ||
+          MD->getDeclName().getNameKind() == DeclarationName::CXXOperatorName)
+        continue;
+      if (MD->isTemplated())
+        continue;
+      Out.push_back({MD->isStatic() ? CXXMGTraitMemberKind::StaticMethod
+                                    : CXXMGTraitMemberKind::InstanceMethod,
+                     MD->getDeclName(), MD->getLocation(), MD, QualType(),
+                     MD->getType(), MD->getTypeSourceInfo()});
+      continue;
+    }
+  }
+  return !Invalid;
+}
+
+static CXXMGTraitMemberSet buildMemberSet(Sema &S, CXXRecordDecl *RD) {
+  CXXMGTraitMemberSet Set;
+  if (!collectMembers(S, RD, Set.Members))
+    Set.Invalid = true;
+  return Set;
+}
+
+static bool evaluateImplements(Sema &S, CXXRecordDecl *Candidate,
+                               CXXRecordDecl *Requirement, bool &Result) {
+  CXXMGTraitMemberSet Cand = buildMemberSet(S, Candidate);
+  CXXMGTraitMemberSet Req = buildMemberSet(S, Requirement);
+  if (Cand.Invalid || Req.Invalid)
+    return false;
+  ASTContext &Ctx = S.Context;
+  Result = llvm::all_of(Req.Members, [&](const auto &R) {
+    return llvm::any_of(Cand.Members,
+                        [&](const auto &C) { return memberMatches(Ctx, R, C); });
+  });
+  return true;
+}
+
+static bool isDependentImplementsOperand(TypeSourceInfo *TSI) {
+  if (!TSI)
+    return false;
+  QualType QT = TSI->getType();
+  return !QT.isNull() &&
+         (QT->isDependentType() || QT->isInstantiationDependentType() ||
+          QT->containsUnexpandedParameterPack());
+}
+
+} // namespace
+
+ExprResult Sema::ActOnCXXMGImplementsExpression(
+    Scope *S, TypeSourceInfo *CandidateTSI, SourceLocation OpLoc,
+    SourceLocation OpEndLoc, bool UsesAngleSyntax,
+    TypeSourceInfo *RequirementTSI, SourceRange Range) {
+  (void)S;
+  if (!getLangOpts().CPlusPlusMG) {
+    Diag(OpLoc, diag::err_cxxmg_implements_requires_cxxmg);
+    return ExprError();
+  }
+  return BuildCXXMGImplementsExpr(CandidateTSI, OpLoc, OpEndLoc,
+                                  UsesAngleSyntax, RequirementTSI, Range);
+}
+
+ExprResult Sema::BuildCXXMGImplementsExpr(
+    TypeSourceInfo *CandidateTSI, SourceLocation OpLoc,
+    SourceLocation OpEndLoc, bool UsesAngleSyntax,
+    TypeSourceInfo *RequirementTSI, SourceRange Range) {
+  if (isDependentImplementsOperand(CandidateTSI) ||
+      isDependentImplementsOperand(RequirementTSI))
+    return CXXMGImplementsExpr::Create(Context, CandidateTSI, RequirementTSI,
+                                       OpLoc, OpEndLoc, Range,
+                                       UsesAngleSyntax);
+
+  CXXRecordDecl *Candidate =
+      resolveImplementsOperand(*this, CandidateTSI, Range.getBegin(),
+                               /*RequirementSide=*/false,
+                               /*Diagnose=*/true);
+  CXXRecordDecl *Requirement = resolveImplementsOperand(
+      *this, RequirementTSI,
+      RequirementTSI ? RequirementTSI->getTypeLoc().getBeginLoc() : OpEndLoc,
+      /*RequirementSide=*/true, /*Diagnose=*/true);
+  if (!Candidate || !Requirement)
+    return ExprError();
+
+  bool Result = false;
+  if (!evaluateImplements(*this, Candidate, Requirement, Result))
+    return ExprError();
+  return CXXBoolLiteralExpr::Create(Context, Result, Context.BoolTy, OpLoc);
+}
