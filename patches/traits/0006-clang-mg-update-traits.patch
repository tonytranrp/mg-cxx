diff --git a/clang/lib/Parse/ParseCXXMGTraitExpr.cpp b/clang/lib/Parse/ParseCXXMGTraitExpr.cpp
new file mode 100644
index 000000000000..883df3239e37
--- /dev/null
+++ b/clang/lib/Parse/ParseCXXMGTraitExpr.cpp
@@ -0,0 +1,162 @@
+//===--- ParseCXXMGTraitExpr.cpp - C++MG trait expressions ----------------===//
+
+#include "clang/Basic/DiagnosticParse.h"
+#include "clang/Parse/Parser.h"
+#include "clang/Parse/RAIIObjectsForParser.h"
+#include "clang/Sema/EnterExpressionEvaluationContext.h"
+
+using namespace clang;
+
+static bool isCXXMGAngleImplements(Parser &P) {
+  return P.getCurToken().is(tok::less) && P.NextToken().is(tok::greater);
+}
+
+static bool isCXXMGImplementsFollowOperator(Parser &P) {
+  return P.NextToken().is(tok::kw_implements) ||
+         (P.NextToken().is(tok::less) &&
+          P.GetLookAheadToken(2).is(tok::greater));
+}
+
+static bool mayStartQualifiedCXXMGImplementsExpression(Parser &P) {
+  unsigned I = 0;
+  if (P.GetLookAheadToken(I).is(tok::coloncolon))
+    ++I;
+  if (!P.GetLookAheadToken(I).is(tok::identifier))
+    return false;
+  ++I;
+  while (P.GetLookAheadToken(I).is(tok::coloncolon) &&
+         P.GetLookAheadToken(I + 1).is(tok::identifier))
+    I += 2;
+  if (P.GetLookAheadToken(I).is(tok::kw_implements))
+    return true;
+
+  if (!P.GetLookAheadToken(I).is(tok::less) ||
+      !P.GetLookAheadToken(I + 1).is(tok::greater))
+    return false;
+
+  tok::TokenKind After = P.GetLookAheadToken(I + 2).getKind();
+  return After == tok::identifier || After == tok::coloncolon ||
+         After == tok::annot_typename || After == tok::kw_typename ||
+         After == tok::kw_decltype || After == tok::kw_struct ||
+         After == tok::kw_class || After == tok::kw_trait;
+}
+
+static bool mayStartCXXMGImplementsExpression(Parser &P) {
+  if (!P.getLangOpts().CPlusPlusMG)
+    return false;
+  tok::TokenKind K = P.getCurToken().getKind();
+  if (K == tok::annot_typename || K == tok::kw_typename ||
+      K == tok::kw_decltype || K == tok::kw_struct || K == tok::kw_class ||
+      K == tok::kw_trait || K == tok::l_paren)
+    return true;
+  if (K == tok::identifier || K == tok::coloncolon)
+    return mayStartQualifiedCXXMGImplementsExpression(P);
+  return false;
+}
+
+bool Parser::ParseCXXMGImplementsTypeOperand(TypeSourceInfo *&TSI,
+                                             SourceRange &Range,
+                                             bool AllowTypeNameFallback) {
+  (void)AllowTypeNameFallback;
+  TSI = nullptr;
+  Range = SourceRange();
+
+  if ((Tok.is(tok::identifier) && NextToken().is(tok::coloncolon)) ||
+      Tok.is(tok::coloncolon)) {
+    if (TryAnnotateTypeOrScopeToken())
+      return false;
+  }
+
+  if (Tok.is(tok::identifier) && isCXXMGImplementsFollowOperator(*this)) {
+    if (TryAnnotateTypeOrScopeToken())
+      return false;
+  }
+
+  SourceLocation Begin = Tok.getLocation();
+  if (Tok.is(tok::annot_typename)) {
+    ParsedType Ty = getTypeAnnotation(Tok).get();
+    Range = Tok.getAnnotationRange();
+    ConsumeAnnotationToken();
+    QualType QT = Actions.GetTypeFromParser(Ty, &TSI);
+    if (QT.isNull())
+      return false;
+    if (!TSI)
+      TSI = Actions.getASTContext().getTrivialTypeSourceInfo(QT, Begin);
+    return true;
+  }
+
+  TypeResult TR = ParseTypeName(&Range);
+  if (TR.isInvalid() || !TR.get())
+    return false;
+  QualType QT = Actions.GetTypeFromParser(TR.get(), &TSI);
+  if (QT.isNull())
+    return false;
+  if (!TSI)
+    TSI = Actions.getASTContext().getTrivialTypeSourceInfo(QT, Begin);
+  return true;
+}
+
+ExprResult Parser::TryParseCXXMGImplementsExpression() {
+  if (!getLangOpts().CPlusPlusMG || !mayStartCXXMGImplementsExpression(*this))
+    return ExprEmpty();
+
+  if (Tok.is(tok::l_paren)) {
+    TentativeParsingAction TPA(*this);
+    ConsumeParen();
+    ExprResult Inner = TryParseCXXMGImplementsExpression();
+    if (!Inner.isUsable() || Tok.isNot(tok::r_paren)) {
+      TPA.Revert();
+      return ExprEmpty();
+    }
+    ConsumeParen();
+    TPA.Commit();
+    return Inner;
+  }
+
+  TentativeParsingAction TPA(*this);
+  TypeSourceInfo *CandidateTSI = nullptr;
+  SourceRange CandidateRange;
+  if (!ParseCXXMGImplementsTypeOperand(CandidateTSI, CandidateRange,
+                                       /*AllowTypeNameFallback=*/false)) {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+
+  SourceLocation OpLoc;
+  SourceLocation OpEndLoc;
+  bool UsesAngleSyntax = false;
+  if (Tok.is(tok::kw_implements)) {
+    OpLoc = ConsumeToken();
+    OpEndLoc = OpLoc;
+  } else if (isCXXMGAngleImplements(*this)) {
+    OpLoc = ConsumeToken();
+    OpEndLoc = ConsumeToken();
+    UsesAngleSyntax = true;
+  } else {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+
+  if (Tok.isOneOf(tok::semi, tok::comma, tok::r_paren, tok::eof)) {
+    TPA.Commit();
+    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
+    return ExprError();
+  }
+
+  TypeSourceInfo *RequirementTSI = nullptr;
+  SourceRange RequirementRange;
+  if (!ParseCXXMGImplementsTypeOperand(RequirementTSI, RequirementRange,
+                                       /*AllowTypeNameFallback=*/true)) {
+    TPA.Commit();
+    Diag(Tok.getLocation(), diag::err_cxxmg_expected_type_after_implements);
+    return ExprError();
+  }
+
+  TPA.Commit();
+  EnterExpressionEvaluationContext Unevaluated(
+      Actions, Sema::ExpressionEvaluationContext::Unevaluated);
+  return Actions.ActOnCXXMGImplementsExpression(
+      getCurScope(), CandidateTSI, OpLoc, OpEndLoc, UsesAngleSyntax,
+      RequirementTSI,
+      SourceRange(CandidateRange.getBegin(), RequirementRange.getEnd()));
+}
