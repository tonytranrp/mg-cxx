+//===- ExprCXXMG.h - C++MG expression AST nodes -----------------*- C++ -*-===//
+
+#ifndef LLVM_CLANG_AST_EXPRCXXMG_H
+#define LLVM_CLANG_AST_EXPRCXXMG_H
+
+#include "clang/AST/Expr.h"
+
+namespace clang {
+
+class CXXMGImplementsExpr final : public Expr {
+  TypeSourceInfo *CandidateTSI = nullptr;
+  TypeSourceInfo *RequirementTSI = nullptr;
+  SourceLocation OpLoc;
+  SourceLocation OpEndLoc;
+  SourceRange Range;
+  bool UsesAngleSyntax = false;
+
+public:
+  CXXMGImplementsExpr(QualType BoolTy, TypeSourceInfo *CandidateTSI,
+                      TypeSourceInfo *RequirementTSI, SourceLocation OpLoc,
+                      SourceLocation OpEndLoc, SourceRange Range,
+                      bool UsesAngleSyntax, ExprDependence Dependence)
+      : Expr(CXXMGImplementsExprClass, BoolTy, VK_PRValue, OK_Ordinary),
+        CandidateTSI(CandidateTSI), RequirementTSI(RequirementTSI),
+        OpLoc(OpLoc), OpEndLoc(OpEndLoc), Range(Range),
+        UsesAngleSyntax(UsesAngleSyntax) {
+    setDependence(Dependence);
+  }
+
+  explicit CXXMGImplementsExpr(EmptyShell Empty)
+      : Expr(CXXMGImplementsExprClass, Empty) {}
+
+  static CXXMGImplementsExpr *
+  Create(ASTContext &Ctx, TypeSourceInfo *CandidateTSI,
+         TypeSourceInfo *RequirementTSI, SourceLocation OpLoc,
+         SourceLocation OpEndLoc, SourceRange Range, bool UsesAngleSyntax);
+  static CXXMGImplementsExpr *CreateEmpty(ASTContext &Ctx);
+
+  TypeSourceInfo *getCandidateTypeSourceInfo() const { return CandidateTSI; }
+  TypeSourceInfo *getRequirementTypeSourceInfo() const {
+    return RequirementTSI;
+  }
+  void setCandidateTypeSourceInfo(TypeSourceInfo *TSI) { CandidateTSI = TSI; }
+  void setRequirementTypeSourceInfo(TypeSourceInfo *TSI) {
+    RequirementTSI = TSI;
+  }
+
+  SourceLocation getOperatorLoc() const { return OpLoc; }
+  SourceLocation getOperatorEndLoc() const { return OpEndLoc; }
+  bool usesAngleSyntax() const { return UsesAngleSyntax; }
+  void setOperatorLoc(SourceLocation Loc) { OpLoc = Loc; }
+  void setOperatorEndLoc(SourceLocation Loc) { OpEndLoc = Loc; }
+  void setUsesAngleSyntax(bool Value) { UsesAngleSyntax = Value; }
+
+  SourceLocation getBeginLoc() const LLVM_READONLY { return Range.getBegin(); }
+  SourceLocation getEndLoc() const LLVM_READONLY { return Range.getEnd(); }
+  SourceLocation getExprLoc() const LLVM_READONLY { return OpLoc; }
+  SourceRange getSourceRange() const LLVM_READONLY { return Range; }
+  void setSourceRange(SourceRange R) { Range = R; }
+
+  child_range children() {
+    return child_range(child_iterator(), child_iterator());
+  }
+  const_child_range children() const {
+    return const_child_range(const_child_iterator(), const_child_iterator());
+  }
+
+  static bool classof(const Stmt *T) {
+    return T->getStmtClass() == CXXMGImplementsExprClass;
+  }
+};
+
+} // namespace clang
+
+#endif
