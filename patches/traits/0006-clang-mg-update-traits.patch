diff --git a/clang/test/CXXMG/traits/trait-implements-qualified.cpp b/clang/test/CXXMG/traits/trait-implements-qualified.cpp
new file mode 100644
index 000000000000..ba54733d1ef2
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-qualified.cpp
@@ -0,0 +1,57 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+namespace backend {
+  trait generator {
+    void generate();
+  };
+
+  trait builder {
+    void build();
+  };
+
+  struct graphviz {
+    void generate();
+  };
+
+  struct ninja {
+    void generate();
+    void build();
+  };
+}
+
+template <typename Backend>
+constexpr bool has_generator() {
+  using backend_t = Backend;
+  return backend_t <> backend::generator;
+}
+
+template <typename Backend>
+constexpr bool has_builder() {
+  using backend_t = Backend;
+  return backend_t implements backend::builder;
+}
+
+static_assert(has_generator<backend::graphviz>());
+static_assert(!has_builder<backend::graphviz>());
+
+static_assert(has_generator<backend::ninja>());
+static_assert(has_builder<backend::ninja>());
+
+namespace mgmake::backend {
+  trait generator {
+    void generate();
+  };
+
+  struct graphviz {
+    void generate();
+  };
+}
+
+template <typename Backend>
+constexpr bool global_qualified_check() {
+  using backend_t = Backend;
+  return backend_t <> ::mgmake::backend::generator;
+}
+
+static_assert(global_qualified_check<mgmake::backend::graphviz>());
diff --git a/clang/test/CXXMG/traits/trait-implements-special-members.cpp b/clang/test/CXXMG/traits/trait-implements-special-members.cpp
new file mode 100644
index 000000000000..d13a841aa6c0
--- /dev/null
+++ b/clang/test/CXXMG/traits/trait-implements-special-members.cpp
@@ -0,0 +1,55 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+trait HasRun {
+  void run();
+};
+
+struct Weird {
+  Weird();
+  Weird(const Weird&);
+  Weird& operator=(const Weird&);
+  ~Weird();
+
+  void run();
+};
+
+static_assert(Weird implements HasRun);
+static_assert(Weird <> HasRun);
+
+trait Generator {
+  void generate();
+};
+
+trait Builder {
+  void build();
+};
+
+struct Graphviz {
+  void generate();
+};
+
+struct Ninja {
+  void generate();
+  void build();
+};
+
+template <typename Backend>
+constexpr bool has_generator() {
+  using backend_t = Backend;
+  constexpr bool result = backend_t <> Generator;
+  return result;
+}
+
+template <typename Backend>
+constexpr bool has_builder() {
+  using backend_t = Backend;
+  constexpr bool result = backend_t implements Builder;
+  return result;
+}
+
+static_assert(has_generator<Graphviz>());
+static_assert(has_builder<Graphviz>() == false);
+
+static_assert(has_generator<Ninja>());
+static_assert(has_builder<Ninja>());
