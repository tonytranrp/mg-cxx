+TraitRequirementDecl *TraitRequirementDecl::Create(
+    ASTContext &C, DeclContext *DC, SourceLocation KeywordLoc,
+    SourceLocation NameLoc, IdentifierInfo *Name, RequirementKind Kind,
+    TypeSourceInfo *FunctionTypeInfo) {
+  auto *D = new (C, DC) TraitRequirementDecl(DC, KeywordLoc, NameLoc, Name,
+                                             Kind, FunctionTypeInfo);
+  D->setAccess(AS_public);
+  return D;
+}
+
+TraitRequirementDecl *
+TraitRequirementDecl::CreateDeserialized(ASTContext &C, GlobalDeclID ID) {
+  return new (C, ID) TraitRequirementDecl(
+      nullptr, SourceLocation(), SourceLocation(), nullptr, AssociatedTypeAny,
+      nullptr);
+}
