Subject: [PATCH 1/3] clang-mg: add conditional-members


diff --git a/clang/include/clang/Parse/Parser.h b/clang/include/clang/Parse/Parser.h
index dc3dc8a4ae0e..de3ead1c64e8 100644
--- a/clang/include/clang/Parse/Parser.h
+++ b/clang/include/clang/Parse/Parser.h
@@ -3544,6 +3544,12 @@ private:
                                             ParsedAttributes &AccessAttrs,
                                             DeclSpec::TST TagType, Decl *Tag);
 
+  /// ParseCXXMGConditionalMember - Parse a C++MG 'if constexpr' member declaration
+  DeclGroupPtrTy
+  ParseCXXMGConditionalMember(AccessSpecifier &AS,
+                              ParsedAttributes &AccessAttrs,
+                              DeclSpec::TST TagType, Decl *Tag);
+
   /// ParseConstructorInitializer - Parse a C++ constructor initializer,
   /// which explicitly initializes the members or base classes of a
   /// class (C++ [class.base.init]). For example, the three initializers
diff --git a/clang/lib/Parse/ParseDeclCXX.cpp b/clang/lib/Parse/ParseDeclCXX.cpp
index 877161b65b6c..a1cd315af5f3 100644
--- a/clang/lib/Parse/ParseDeclCXX.cpp
+++ b/clang/lib/Parse/ParseDeclCXX.cpp
@@ -3477,6 +3477,9 @@ Parser::DeclGroupPtrTy Parser::ParseCXXClassMemberDeclarationWithPragmas(
   case tok::annot_pragma_openacc:
     return ParseOpenACCDirectiveDecl(AS, AccessAttrs, TagType, TagDecl);
 
+  case tok::kw_if:
+    return ParseCXXMGConditionalMember(AS, AccessAttrs, TagType, TagDecl);
+
   default:
     if (tok::isPragmaAnnotation(Tok.getKind())) {
       Diag(Tok.getLocation(), diag::err_pragma_misplaced_in_decl)
@@ -3490,6 +3493,13 @@ Parser::DeclGroupPtrTy Parser::ParseCXXClassMemberDeclarationWithPragmas(
   }
 }
 
+Parser::DeclGroupPtrTy Parser::ParseCXXMGConditionalMember(AccessSpecifier &AS,
+                              ParsedAttributes &AccessAttrs,
+                              DeclSpec::TST TagType, Decl *Tag) {
+  // TODO: Implement idk how yet
+  return nullptr;
+}
+
 void Parser::ParseCXXMemberSpecification(SourceLocation RecordLoc,
                                          SourceLocation AttrFixitLoc,
                                          ParsedAttributes &Attrs,
