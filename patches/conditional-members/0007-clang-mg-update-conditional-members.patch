+//===- DeclCXXMG.h - Classes for representing C++MG declarations --*- C++MG -*-=====//
+//
+/// \file
+/// Defines the C++MG Decl subclasses.
+//
+//===----------------------------------------------------------------------===//
+
+#ifndef LLVM_CLANG_AST_DECLCXXMG_H
+#define LLVM_CLANG_AST_DECLCXXMG_H
+
+#include "clang/AST/DeclBase.h"
+#include "clang/AST/ASTVector.h"
+#include "clang/Basic/Specifiers.h"
+#include "llvm/ADT/ArrayRef.h"
+
+namespace clang {
+
+class ASTContext;
+class Expr;
+
+/// Represents one arm of a class-scope C++MG conditional member chain.
+///
+/// Example:
+///
+///   if constexpr (A) {
+///     int a;
+///   } else if constexpr (B) {
+///     int b;
+///   } else {
+///     int c;
+///   }
+///
+/// This would be represented as three arms:
+///
+///   arm 0: condition A, pattern decls for `a`
+///   arm 1: condition B, pattern decls for `b`
+///   arm 2: no condition, pattern decls for `c`
+///
+/// The final `else` arm has no condition. In that case, `Condition` is null
+/// and `IsElseArm` is true.
+///
+/// These declarations are inactive member patterns. They should not be treated
+/// as active members of the parent CXXRecordDecl until Sema selects an arm and
+/// materializes its declarations into the real class/struct.
+struct CXXMGConditionalMemberArm {
+  Expr *Condition = nullptr;
+  llvm::ArrayRef<Decl *> Decls;
+
+  AccessSpecifier StartAS = AS_none;
+
+  SourceRange Range;
+
+  bool IsElseArm = false;
+
+  CXXMGConditionalMemberArm() = default;
+
+  CXXMGConditionalMemberArm(Expr *Condition,
+                            llvm::ArrayRef<Decl *> Decls,
+                            AccessSpecifier StartAS,
+                            SourceRange Range,
+                            bool IsElseArm)
+      : Condition(Condition),
+        Decls(Decls),
+        StartAS(StartAS),
+        Range(Range),
+        IsElseArm(IsElseArm) {}
+
+  bool hasCondition() const {
+    return Condition != nullptr;
+  }
+
+  bool isElseArm() const {
+    return IsElseArm;
+  }
+
+  SourceRange getSourceRange() const {
+    return Range;
+  }
+};
+
+/// Represents a complete class-scope C++MG conditional member declaration.
+///
+/// Example:
+///
+///   template <bool A, bool B>
+///   struct S {
+///     if constexpr (A) {
+///       int a;
+///     } else if constexpr (B) {
+///       int b;
+///     } else {
+///       int c;
+///     }
+///   };
+///
+/// This declaration represents the whole conditional chain, not just one
+/// branch. Each `if constexpr`, `else if constexpr`, and final `else` body is
+/// stored as a `CXXMGConditionalMemberArm`.
+///
+/// The arms are checked in source order. During materialization, Sema selects
+/// the first arm whose condition evaluates to true. If no conditional arm is
+/// selected, the final unconditional `else` arm is selected if present.
+///
+/// The declarations inside each arm are stored as inactive member patterns.
+/// They should not affect lookup, layout, field lists, special member
+/// generation, or normal class semantics until the selected arm is materialized
+/// into the actual CXXRecordDecl.
+class CXXMGConditionalMemberDecl final : public Decl {
+  ASTVector<CXXMGConditionalMemberArm> Arms;
+  ASTVector<Decl *> OwnedDecls;
+
+  SourceLocation IfLoc;
+
+  CXXMGConditionalMemberDecl(DeclContext *DC, SourceLocation IfLoc)
+      : Decl(CXXMGConditionalMember, DC, IfLoc),
+        IfLoc(IfLoc) {}
+
+public:
+  static CXXMGConditionalMemberDecl *
+  Create(ASTContext &Ctx,
+         DeclContext *DC,
+         SourceLocation IfLoc,
+         llvm::ArrayRef<CXXMGConditionalMemberArm> ParsedArms);
+
+  llvm::ArrayRef<CXXMGConditionalMemberArm> arms() const {
+    return Arms;
+  }
+
+  unsigned getNumArms() const {
+    return Arms.size();
+  }
+
+  const CXXMGConditionalMemberArm &getArm(unsigned I) const {
+    return Arms[I];
+  }
+
+  SourceLocation getIfLoc() const {
+    return IfLoc;
+  }
+
+  SourceRange getSourceRange() const override {
+    if (Arms.empty())
+      return SourceRange(IfLoc, IfLoc);
+
+    return SourceRange(IfLoc, Arms.back().getSourceRange().getEnd());
+  }
+
+  static bool classof(const Decl *D) {
+    return D->getKind() == CXXMGConditionalMember;
+  }
+};
+
+} // namespace clang
+
+#endif // LLVM_CLANG_AST_DECLCXXMG_H
