diff --git a/clang/include/clang/AST/RecursiveASTVisitor.h b/clang/include/clang/AST/RecursiveASTVisitor.h
index b5be0910194b..7728ff8687c8 100644
--- a/clang/include/clang/AST/RecursiveASTVisitor.h
+++ b/clang/include/clang/AST/RecursiveASTVisitor.h
@@ -2504,6 +2504,16 @@ DEF_TRAVERSE_DECL(ImplicitConceptSpecializationDecl, {
   TRY_TO(TraverseTemplateArguments(D->getTemplateArguments()));
 })
 
+DEF_TRAVERSE_DECL(CXXMGConditionalMemberDecl, {
+  for (const CXXMGConditionalMemberArm &Arm : D->arms()) {
+    if (Arm.Condition)
+      TRY_TO(TraverseStmt(Arm.Condition));
+
+    for (Decl *PatternDecl : Arm.Decls)
+      TRY_TO(TraverseDecl(PatternDecl));
+  }
+})
+
 #undef DEF_TRAVERSE_DECL
 
 // ----------------- Stmt traversal -----------------
