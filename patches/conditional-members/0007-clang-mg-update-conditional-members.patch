new file mode 100644
index 000000000000..7b4450f48b5e
--- /dev/null
+++ b/clang/lib/AST/DeclCXXMG.cpp
@@ -0,0 +1,48 @@
+//===- DeclCXXMG.cpp - C++MG Declaration AST Node Implementation ----------===//
+//
+// This file implements the C++MG related Decl classes.
+//
+//===----------------------------------------------------------------------===//
+
+#include "clang/AST/DeclCXXMG.h"
+#include "clang/AST/ASTContext.h"
+#include "clang/AST/Expr.h"
+
+using namespace clang;
+
+CXXMGConditionalMemberDecl *
+CXXMGConditionalMemberDecl::Create(
+    ASTContext &Ctx,
+    DeclContext *DC,
+    SourceLocation IfLoc,
+    llvm::ArrayRef<CXXMGConditionalMemberArm> ParsedArms) {
+  auto *D = new (Ctx, DC) CXXMGConditionalMemberDecl(DC, IfLoc);
+
+  unsigned TotalDecls = 0;
+  for (const CXXMGConditionalMemberArm &Arm : ParsedArms)
+    TotalDecls += Arm.Decls.size();
+
+  D->Arms.reserve(Ctx, ParsedArms.size());
+  D->OwnedDecls.reserve(Ctx, TotalDecls);
+
+  for (const CXXMGConditionalMemberArm &Arm : ParsedArms) {
+    unsigned FirstDecl = D->OwnedDecls.size();
+
+    D->OwnedDecls.append(Ctx, Arm.Decls.begin(), Arm.Decls.end());
+
+    llvm::ArrayRef<Decl *> StableDecls(
+        D->OwnedDecls.begin() + FirstDecl,
+        Arm.Decls.size());
+
+    D->Arms.push_back(
+        CXXMGConditionalMemberArm{
+            Arm.Condition,
+            StableDecls,
+            Arm.StartAS,
+            Arm.Range,
+            Arm.IsElseArm},
+        Ctx);
+  }
+
+  return D;
+}
