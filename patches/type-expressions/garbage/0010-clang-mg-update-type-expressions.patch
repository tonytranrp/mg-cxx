From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mike <michaelgorney4@gmail.com>
Date: Sat, 30 May 2026 01:23:18 -0400
Subject: [PATCH] clang-mg: update type-expressions

---
 clang/include/clang/AST/ExprCXXMG.h | 23 ++++++++++-------------
 clang/lib/AST/Expr.cpp              |  3 +--
 2 files changed, 11 insertions(+), 15 deletions(-)

diff --git a/clang/include/clang/AST/ExprCXXMG.h b/clang/include/clang/AST/ExprCXXMG.h
index cae1e9bcffde..2f6892aae8b9 100644
--- a/clang/include/clang/AST/ExprCXXMG.h
+++ b/clang/include/clang/AST/ExprCXXMG.h
@@ -12,12 +12,13 @@
 #include "clang/AST/CXXMGTypeExpr.h"
 #include "clang/AST/Expr.h"
 
+#include <optional>
+
 namespace clang {
 
 class CXXMGTypeCheckExpr final : public Expr {
   CXXMGTypeExprNode *ExprNode = nullptr;
-  bool HasKnownValue = false;
-  bool KnownValue = false;
+  std::optional<bool> KnownValue;
 
 public:
   // CXXMGTypeCheckExpr represents a C++MG structural type predicate.
@@ -29,11 +30,9 @@ public:
   // evaluator must not recompute the predicate; it only consumes the cached
   // value.
   CXXMGTypeCheckExpr(QualType BoolTy, CXXMGTypeExprNode *ExprNode,
-                     ExprDependence Dependence, bool HasKnownValue = false,
-                     bool KnownValue = false)
+                     ExprDependence Dependence, std::optional<bool> KnownValue = std::nullopt)
       : Expr(CXXMGTypeCheckExprClass, BoolTy, VK_PRValue, OK_Ordinary),
-        ExprNode(ExprNode), HasKnownValue(HasKnownValue),
-        KnownValue(KnownValue) {
+        ExprNode(ExprNode), KnownValue(KnownValue) {
     setDependence(Dependence);
   }
 
@@ -50,21 +49,19 @@ public:
   CXXMGTypeExprNode *getTypeExprNode() const { return ExprNode; }
   void setTypeExprNode(CXXMGTypeExprNode *Node) { ExprNode = Node; }
 
-  bool hasKnownValue() const { return HasKnownValue; }
+  bool hasKnownValue() const { return KnownValue.has_value(); }
 
   bool getKnownValue() const {
-    assert(HasKnownValue && "CXXMGTypeCheckExpr has no known value");
-    return KnownValue;
+    assert(hasKnownValue() && "CXXMGTypeCheckExpr has no known value");
+    return KnownValue.value();
   }
 
-  void setKnownValue(bool Value) {
-    HasKnownValue = true;
+  void setKnownValue(std::optional<bool> Value) {
     KnownValue = Value;
   }
 
   void clearKnownValue() {
-    HasKnownValue = false;
-    KnownValue = false;
+    KnownValue.reset();
   }
 
   SourceLocation getBeginLoc() const LLVM_READONLY {
diff --git a/clang/lib/AST/Expr.cpp b/clang/lib/AST/Expr.cpp
index 40ba6b7b036d..6143a6b3df8e 100644
--- a/clang/lib/AST/Expr.cpp
+++ b/clang/lib/AST/Expr.cpp
@@ -69,8 +69,7 @@ CXXMGTypeCheckExpr *
 CXXMGTypeCheckExpr::CreateResolved(ASTContext &Ctx,
                                    CXXMGTypeExprNode *ExprNode, bool Value) {
   return new (Ctx)
-      CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode, ExprDependence::None,
-                         /*HasKnownValue=*/true, Value);
+      CXXMGTypeCheckExpr(Ctx.BoolTy, ExprNode, ExprDependence::None, Value);
 }
 
 CXXMGTypeCheckExpr *CXXMGTypeCheckExpr::CreateEmpty(ASTContext &Ctx) {
-- 
2.54.0

