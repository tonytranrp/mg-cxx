+  //
+  // Handles:
+  //   generator && backend_t
+  //
+  // This is the original safe annotation case. It only runs when the identifier
+  // is directly followed by a C++MG type-expression operator.
   if (Tok.is(tok::identifier) &&
-      NextToken().isOneOf(tok::plus, tok::minus, tok::ampamp,
-                          tok::pipepipe)) {
+      isCXXMGTypeExprPrimaryFollowOperator(NextToken().getKind())) {
     if (TryAnnotateTypeOrScopeToken())
       return false;
   }
 
   if (Tok.is(tok::annot_typename) &&
-      NextToken().isOneOf(tok::plus, tok::minus, tok::ampamp,
-                          tok::pipepipe)) {
+      isCXXMGTypeExprPrimaryFollowOperator(NextToken().getKind())) {
     SourceRange Range = Tok.getAnnotationRange();
     ParsedType Ty = getTypeAnnotation(Tok).get();
     if (!Ty)
@@ -95,8 +119,7 @@ bool Parser::ParseCXXMGTypeExprPrimary(ParsedCXXMGTypeExpr &Out,
   }
 
