-      NextToken().isOneOf(tok::plus, tok::minus, tok::ampamp,
-                          tok::pipepipe)) {
+      isCXXMGTypeExprPrimaryFollowOperator(NextToken().getKind())) {
     SourceLocation NameLoc = Tok.getLocation();
     IdentifierInfo *II = Tok.getIdentifierInfo();
     ParsedType Ty = Actions.getTypeName(*II, NameLoc, getCurScope());
diff --git a/clang/test/CXXMG/type-expressions/type-predicate-do-not-steal-value-expressions.cpp b/clang/test/CXXMG/type-expressions/type-predicate-do-not-steal-value-expressions.cpp
new file mode 100644
index 000000000000..b564df296fd4
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-predicate-do-not-steal-value-expressions.cpp
@@ -0,0 +1,53 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+// This mimics libc++ patterns from __compare/ordering.h. These are normal C++
+// value expressions and must not be parsed as C++MG type expressions.
+
+template <class A, class B>
+inline constexpr bool is_same_v = false;
+
+template <class A>
+inline constexpr bool is_same_v<A, A> = true;
+
+template <class _Tp, class... _Args>
+inline constexpr bool one_of_v = (is_same_v<_Tp, _Args> || ...);
+
+static_assert(one_of_v<int, char, int>);
+static_assert(!one_of_v<int, char, long>);
+
+struct partial_ordering {
+  static const partial_ordering less;
+  static const partial_ordering greater;
+  static const partial_ordering equivalent;
+
+  int value;
+
+  constexpr explicit partial_ordering(int v) : value(v) {}
+};
+
+inline constexpr partial_ordering partial_ordering::less{-1};
+inline constexpr partial_ordering partial_ordering::greater{1};
+inline constexpr partial_ordering partial_ordering::equivalent{0};
+
+constexpr partial_ordering cmp(int __v) {
+  return __v < 0 ? partial_ordering::greater
+                 : (__v > 0 ? partial_ordering::less
+                             : partial_ordering::equivalent);
+}
+
+static_assert(cmp(-1).value == 1);
+static_assert(cmp(1).value == -1);
+static_assert(cmp(0).value == 0);
+
+namespace ns {
+  int value();
+  bool flag();
+}
+
+void normal_qualified_calls_are_not_stolen() {
+  bool a = ns::flag();
+  int b = ns::value();
+  (void)a;
+  (void)b;
+}
diff --git a/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp b/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp
index 7127c1dfa3ff..f07f24f32ef8 100644
--- a/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp
+++ b/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp
@@ -1,29 +1,14 @@
 // RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
 
-namespace ns {
-  int value();
-  bool flag();
-}
-
-void normal_cpp_expressions_are_not_stolen() {
-  // These should be parsed by normal C++, not by the C++MG type-expression parser.
-  bool a = ns::flag();
-  int b = ns::value();
-  (void)a;
-  (void)b;
-}
+struct ordering {
+  static const int less = -1;
+  static const int greater = 1;
+};
 
-namespace backend {
-  trait generator {
-    void generate();
-  };
+constexpr int choose(bool b) {
+  return b ? ordering::less : ordering::greater;
 }
 
-struct no_generate {};
-
-void bad_type_predicate_operand() {
-  // This is still a C++MG predicate syntactically, but the RHS is not a type.
-  // The exact diagnostic may differ depending on your current diagnostic wiring.
-  constexpr bool x = backend::generator && 123; // expected-error {{expected a type}}
-  (void)x;
-}
+static_assert(choose(true) == -1);
+static_assert(choose(false) == 1);
