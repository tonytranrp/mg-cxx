From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mike <michaelgorney4@gmail.com>
Date: Sat, 30 May 2026 01:42:41 -0400
Subject: [PATCH] clang-mg: update type-expressions

---
 clang/lib/Parse/ParseCXXMGTypeExpr.cpp        | 11 +++-
 .../type-predicate-qualified-constexpr.cpp    | 60 +++++++++++++++++++
 .../type-predicate-qualified-negative.cpp     | 29 +++++++++
 3 files changed, 97 insertions(+), 3 deletions(-)
 create mode 100644 clang/test/CXXMG/type-expressions/type-predicate-qualified-constexpr.cpp
 create mode 100644 clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp

diff --git a/clang/lib/Parse/ParseCXXMGTypeExpr.cpp b/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
index e1f167655a3c..d8c3fbca3e03 100644
--- a/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
+++ b/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
@@ -27,10 +27,14 @@ static bool mayStartCXXMGTypePredicate(Parser &P) {
       K == tok::kw_struct || K == tok::kw_class || K == tok::kw_trait)
     return true;
 
+  if (K == tok::coloncolon)
+    return true;
+
   if (K == tok::identifier) {
     tok::TokenKind Next = P.NextToken().getKind();
     return Next == tok::plus || Next == tok::minus || Next == tok::ampamp ||
-           Next == tok::pipepipe;
+           Next == tok::pipepipe || Next == tok::coloncolon ||
+           Next == tok::less;
   }
 
   if (K == tok::l_paren) {
@@ -38,7 +42,8 @@ static bool mayStartCXXMGTypePredicate(Parser &P) {
     tok::TokenKind Second = P.GetLookAheadToken(2).getKind();
     return First == tok::identifier &&
            (Second == tok::plus || Second == tok::minus ||
-            Second == tok::ampamp || Second == tok::pipepipe);
+            Second == tok::ampamp || Second == tok::pipepipe ||
+            Second == tok::coloncolon || Second == tok::less);
   }
 
   return false;
@@ -243,7 +248,7 @@ ExprResult Parser::TryParseCXXMGTypePredicateExpression() {
   ParsedCXXMGTypeExpr TE;
   if (!TryParseCXXMGTypeExpression(TE, /*AllowPredicates=*/true,
                                    /*RequireTypeProducingResult=*/false,
-                                   /*AllowTypeNameFallback=*/false) ||
+                                   /*AllowTypeNameFallback=*/true) ||
       !TE.SawTypeExprOperator) {
     TPA.Revert();
     return ExprEmpty();
diff --git a/clang/test/CXXMG/type-expressions/type-predicate-qualified-constexpr.cpp b/clang/test/CXXMG/type-expressions/type-predicate-qualified-constexpr.cpp
new file mode 100644
index 000000000000..fd10ed34ee07
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-predicate-qualified-constexpr.cpp
@@ -0,0 +1,60 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+namespace backend {
+  trait generator {
+    void generate();
+  };
+
+  trait builder {
+    void build();
+  };
+
+  struct graphviz {
+    void generate();
+  };
+
+  struct ninja {
+    void generate();
+    void build();
+  };
+}
+
+template <typename Backend>
+constexpr bool has_generator() {
+  using backend_t = Backend;
+  static constexpr bool is_gen = backend::generator && backend_t;
+  return is_gen;
+}
+
+template <typename Backend>
+constexpr bool has_builder() {
+  using backend_t = Backend;
+  static constexpr bool is_build = backend::builder && backend_t;
+  return is_build;
+}
+
+static_assert(has_generator<backend::graphviz>());
+static_assert(!has_builder<backend::graphviz>());
+
+static_assert(has_generator<backend::ninja>());
+static_assert(has_builder<backend::ninja>());
+
+namespace mgmake::backend {
+  trait generator {
+    void generate();
+  };
+
+  struct graphviz {
+    void generate();
+  };
+}
+
+template <typename Backend>
+constexpr bool test_global_qualified() {
+  using backend_t = Backend;
+  static constexpr bool value = ::mgmake::backend::generator && backend_t;
+  return value;
+}
+
+static_assert(test_global_qualified<mgmake::backend::graphviz>());
diff --git a/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp b/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp
new file mode 100644
index 000000000000..7127c1dfa3ff
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-predicate-qualified-negative.cpp
@@ -0,0 +1,29 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+namespace ns {
+  int value();
+  bool flag();
+}
+
+void normal_cpp_expressions_are_not_stolen() {
+  // These should be parsed by normal C++, not by the C++MG type-expression parser.
+  bool a = ns::flag();
+  int b = ns::value();
+  (void)a;
+  (void)b;
+}
+
+namespace backend {
+  trait generator {
+    void generate();
+  };
+}
+
+struct no_generate {};
+
+void bad_type_predicate_operand() {
+  // This is still a C++MG predicate syntactically, but the RHS is not a type.
+  // The exact diagnostic may differ depending on your current diagnostic wiring.
+  constexpr bool x = backend::generator && 123; // expected-error {{expected a type}}
+  (void)x;
+}
-- 
2.54.0

