diff --git a/clang/lib/Sema/SemaCXXMGTypeExpr.cpp b/clang/lib/Sema/SemaCXXMGTypeExpr.cpp
new file mode 100644
index 000000000000..b87cf3a38595
--- /dev/null
+++ b/clang/lib/Sema/SemaCXXMGTypeExpr.cpp
@@ -0,0 +1,563 @@
+//===------ SemaCXXMGTypeExpr.cpp - C++MG Type Expressions ---------------===//
+//
+//  This file implements semantic analysis for C++MG structural type
+//  expressions. This first slice handles non-dependent aliases and predicates.
+//
+//===----------------------------------------------------------------------===//
+
+#include "clang/Sema/Sema.h"
+#include "clang/AST/ASTContext.h"
+#include "clang/AST/ASTConsumer.h"
+#include "clang/AST/DeclCXX.h"
+#include "clang/AST/ExprCXX.h"
+#include "clang/Basic/DiagnosticSema.h"
+#include "clang/Sema/DeclSpec.h"
+
+using namespace clang;
+
+namespace {
+
+enum class CXXMGMemberKind {
+  Field,
+  StaticData,
+  InstanceMethod,
+  StaticMethod,
+  TypeAliasExact,
+  AssociatedTypeAny,
+  StaticFunctionAnyReturn
+};
+
+struct CXXMGMemberDescriptor {
+  CXXMGMemberKind Kind;
+  DeclarationName Name;
+  SourceLocation Loc;
+  NamedDecl *SourceDecl = nullptr;
+
+  QualType ValueType;
+  TypeSourceInfo *ValueTypeInfo = nullptr;
+
+  QualType FunctionType;
+  TypeSourceInfo *FunctionTypeInfo = nullptr;
+
+  AccessSpecifier Access = AS_public;
+};
+
+struct CXXMGMemberSet {
+  SmallVector<CXXMGMemberDescriptor, 16> Members;
+  bool Invalid = false;
+  bool IsTrait = false;
+};
+
+static StringRef getCXXMGOpName(tok::TokenKind Op) {
+  if (const char *Spelling = tok::getPunctuatorSpelling(Op))
+    return Spelling;
+  return tok::getTokenName(Op);
+}
+
+static bool sameValueType(ASTContext &Ctx, QualType A, QualType B) {
+  return !A.isNull() && !B.isNull() &&
+         Ctx.hasSameType(A.getCanonicalType(), B.getCanonicalType());
+}
+
+static const FunctionProtoType *getProto(QualType T) {
+  return T.isNull() ? nullptr : T->getAs<FunctionProtoType>();
+}
+
+static bool sameFunctionSignature(ASTContext &Ctx,
+                                  const CXXMGMemberDescriptor &A,
+                                  const CXXMGMemberDescriptor &B,
+                                  bool IgnoreReturnType) {
+  const auto *AP = getProto(A.FunctionType);
+  const auto *BP = getProto(B.FunctionType);
+  if (!AP || !BP)
+    return false;
+  if (!IgnoreReturnType &&
+      !Ctx.hasSameType(AP->getReturnType().getCanonicalType(),
+                       BP->getReturnType().getCanonicalType()))
+    return false;
+  if (AP->getNumParams() != BP->getNumParams())
+    return false;
+  if (AP->getMethodQuals() != BP->getMethodQuals() ||
+      AP->getRefQualifier() != BP->getRefQualifier())
+    return false;
+  for (unsigned I = 0, E = AP->getNumParams(); I != E; ++I)
+    if (!Ctx.hasSameType(AP->getParamType(I).getCanonicalType(),
+                         BP->getParamType(I).getCanonicalType()))
+      return false;
+  return true;
+}
+
+static bool memberMatches(ASTContext &Ctx, const CXXMGMemberDescriptor &Req,
+                          const CXXMGMemberDescriptor &Cand) {
+  if (Req.Name != Cand.Name)
+    return false;
+
+  if (Req.Kind == CXXMGMemberKind::AssociatedTypeAny)
+    return Cand.Kind == CXXMGMemberKind::AssociatedTypeAny ||
+           Cand.Kind == CXXMGMemberKind::TypeAliasExact;
+
+  if (Req.Kind == CXXMGMemberKind::StaticFunctionAnyReturn)
+    return Cand.Kind == CXXMGMemberKind::StaticMethod &&
+           sameFunctionSignature(Ctx, Req, Cand, /*IgnoreReturnType=*/true);
+
+  if (Req.Kind != Cand.Kind)
+    return false;
+
+  switch (Req.Kind) {
+  case CXXMGMemberKind::Field:
+  case CXXMGMemberKind::StaticData:
+  case CXXMGMemberKind::TypeAliasExact:
+    return sameValueType(Ctx, Req.ValueType, Cand.ValueType);
+  case CXXMGMemberKind::InstanceMethod:
+  case CXXMGMemberKind::StaticMethod:
+    return sameFunctionSignature(Ctx, Req, Cand, /*IgnoreReturnType=*/false);
+  case CXXMGMemberKind::AssociatedTypeAny:
+  case CXXMGMemberKind::StaticFunctionAnyReturn:
+    llvm_unreachable("handled above");
+  }
+  llvm_unreachable("unknown C++MG member kind");
+}
+
+static bool canCoexist(ASTContext &Ctx, bool ResultIsTrait,
+                       const CXXMGMemberDescriptor &A,
+                       const CXXMGMemberDescriptor &B) {
+  if (A.Name != B.Name)
+    return true;
+
+  if (ResultIsTrait) {
+    if (A.Kind == CXXMGMemberKind::AssociatedTypeAny &&
+        B.Kind == CXXMGMemberKind::AssociatedTypeAny)
+      return true;
+    if ((A.Kind == CXXMGMemberKind::AssociatedTypeAny &&
+         B.Kind == CXXMGMemberKind::TypeAliasExact) ||
+        (A.Kind == CXXMGMemberKind::TypeAliasExact &&
+         B.Kind == CXXMGMemberKind::AssociatedTypeAny))
+      return true;
+    if (A.Kind == CXXMGMemberKind::TypeAliasExact &&
+        B.Kind == CXXMGMemberKind::TypeAliasExact)
+      return sameValueType(Ctx, A.ValueType, B.ValueType);
+  }
+
+  bool AMethod = A.Kind == CXXMGMemberKind::InstanceMethod ||
+                 A.Kind == CXXMGMemberKind::StaticMethod;
+  bool BMethod = B.Kind == CXXMGMemberKind::InstanceMethod ||
+                 B.Kind == CXXMGMemberKind::StaticMethod;
+  if (AMethod && BMethod)
+    return !sameFunctionSignature(Ctx, A, B, /*IgnoreReturnType=*/false);
+
+  return false;
+}
+
+class CXXMGTypeExprSema {
+  Sema &S;
+  ASTContext &Ctx;
+
+public:
+  CXXMGTypeExprSema(Sema &S) : S(S), Ctx(S.Context) {}
+
+  CXXRecordDecl *resolveOperand(TypeSourceInfo *TSI, SourceLocation Loc,
+                                bool Diagnose) {
+    if (!TSI) {
+      if (Diagnose)
+        S.Diag(Loc, diag::err_cxxmg_type_expr_expected_type_operand);
+      return nullptr;
+    }
+
+    QualType QT = TSI->getType();
+    if (QT->isDependentType()) {
+      if (Diagnose)
+        S.Diag(Loc, diag::err_cxxmg_type_expr_expected_type_operand);
+      return nullptr;
+    }
+    if (QT->isReferenceType() || QT->isPointerType() || QT->isArrayType() ||
+        QT->isFunctionType()) {
+      if (Diagnose)
+        S.Diag(Loc, diag::err_cxxmg_type_expr_invalid_operand) << QT;
+      return nullptr;
+    }
+
+    QT = QT.getUnqualifiedType();
+    auto *RD = QT.getDesugaredType(Ctx)->getAsCXXRecordDecl();
+    if (!RD) {
+      if (Diagnose)
+        S.Diag(Loc, diag::err_cxxmg_type_expr_invalid_operand) << QT;
+      return nullptr;
+    }
+    if (RD->isUnion()) {
+      if (Diagnose)
+        S.Diag(Loc, diag::err_cxxmg_type_expr_union_operand) << QT;
+      return nullptr;
+    }
+    if (!RD->hasDefinition()) {
+      if (Diagnose)
+        S.Diag(Loc, diag::err_cxxmg_type_expr_incomplete_operand) << QT;
+      return nullptr;
+    }
+    RD = RD->getDefinitionOrSelf();
+    return RD->isInvalidDecl() ? nullptr : RD;
+  }
+
+  bool collect(CXXRecordDecl *RD, SmallVectorImpl<CXXMGMemberDescriptor> &Out,
+               SourceLocation OpLoc) {
+    bool Invalid = false;
+    for (Decl *D : RD->decls()) {
+      if (auto *FD = dyn_cast<FieldDecl>(D)) {
+        if (!FD->getDeclName() || FD->isBitField()) {
+          S.Diag(FD->getLocation(), diag::err_cxxmg_type_expr_unsupported_member)
+              << FD;
+          Invalid = true;
+          continue;
+        }
+        CXXMGMemberDescriptor M;
+        M.Kind = CXXMGMemberKind::Field;
+        M.Name = FD->getDeclName();
+        M.Loc = FD->getLocation();
+        M.SourceDecl = FD;
+        M.ValueType = FD->getType();
+        M.ValueTypeInfo = FD->getTypeSourceInfo();
+        M.Access = FD->getAccess();
+        Out.push_back(M);
+        continue;
+      }
+
+      if (auto *VD = dyn_cast<VarDecl>(D)) {
+        if (!VD->isStaticDataMember())
+          continue;
+        CXXMGMemberDescriptor M;
+        M.Kind = CXXMGMemberKind::StaticData;
+        M.Name = VD->getDeclName();
+        M.Loc = VD->getLocation();
+        M.SourceDecl = VD;
+        M.ValueType = VD->getType();
+        M.ValueTypeInfo = VD->getTypeSourceInfo();
+        M.Access = VD->getAccess();
+        Out.push_back(M);
+        continue;
+      }
+
+      if (auto *TD = dyn_cast<TypedefNameDecl>(D)) {
+        CXXMGMemberDescriptor M;
+        M.Kind = CXXMGMemberKind::TypeAliasExact;
+        M.Name = TD->getDeclName();
+        M.Loc = TD->getLocation();
+        M.SourceDecl = TD;
+        M.ValueType = TD->getUnderlyingType();
+        M.ValueTypeInfo = TD->getTypeSourceInfo();
+        M.Access = TD->getAccess();
+        Out.push_back(M);
+        continue;
+      }
+
+      if (auto *TR = dyn_cast<TraitRequirementDecl>(D)) {
+        CXXMGMemberDescriptor M;
+        M.Kind = TR->isAssociatedTypeAny()
+                     ? CXXMGMemberKind::AssociatedTypeAny
+                     : CXXMGMemberKind::StaticFunctionAnyReturn;
+        M.Name = TR->getDeclName();
+        M.Loc = TR->getLocation();
+        M.SourceDecl = TR;
+        M.FunctionTypeInfo = TR->getFunctionTypeInfo();
+        if (M.FunctionTypeInfo)
+          M.FunctionType = M.FunctionTypeInfo->getType();
+        else if (TR->isStaticFunctionAnyReturn())
+          M.FunctionType = Ctx.getFunctionType(Ctx.VoidTy, {},
+                                               FunctionProtoType::ExtProtoInfo());
+        Out.push_back(M);
+        continue;
+      }
+
+      if (auto *MD = dyn_cast<CXXMethodDecl>(D)) {
+        if (isa<CXXConstructorDecl>(MD) || isa<CXXDestructorDecl>(MD) ||
+            isa<CXXConversionDecl>(MD) ||
+            MD->getDeclName().getNameKind() == DeclarationName::CXXOperatorName ||
+            MD->isTemplated()) {
+          S.Diag(MD->getLocation(),
+                 diag::err_cxxmg_type_expr_unsupported_member)
+              << MD;
+          Invalid = true;
+          continue;
+        }
+        CXXMGMemberDescriptor M;
+        M.Kind = MD->isStatic() ? CXXMGMemberKind::StaticMethod
+                                : CXXMGMemberKind::InstanceMethod;
+        M.Name = MD->getDeclName();
+        M.Loc = MD->getLocation();
+        M.SourceDecl = MD;
+        M.FunctionType = MD->getType();
+        M.FunctionTypeInfo = MD->getTypeSourceInfo();
+        M.Access = MD->getAccess();
+        Out.push_back(M);
+        continue;
+      }
+    }
+    if (Invalid)
+      S.Diag(OpLoc, diag::note_cxxmg_type_expr_in_result);
+    return !Invalid;
+  }
+
+  CXXMGMemberSet buildSet(const ParsedCXXMGTypeExpr &TE) {
+    if (TE.K == ParsedCXXMGTypeExpr::Operand) {
+      CXXMGMemberSet Set;
+      CXXRecordDecl *RD = resolveOperand(TE.OperandTSI, TE.BeginLoc, true);
+      if (!RD) {
+        Set.Invalid = true;
+        return Set;
+      }
+      Set.IsTrait = RD->isTrait();
+      Set.Invalid = !collect(RD, Set.Members, TE.BeginLoc);
+      return Set;
+    }
+
+    CXXMGMemberSet L = buildSet(*TE.LHS);
+    CXXMGMemberSet R = buildSet(*TE.RHS);
+    if (L.Invalid || R.Invalid) {
+      L.Invalid = true;
+      return L;
+    }
+
+    if (TE.Op == tok::plus)
+      return composePlus(L, R, TE.OpLoc);
+    if (TE.Op == tok::minus)
+      return composeMinus(L, R, TE.OpLoc);
+
+    S.Diag(TE.OpLoc, diag::err_cxxmg_type_expr_invalid_operator_predicate_sema)
+        << getCXXMGOpName(TE.Op);
+    L.Invalid = true;
+    return L;
+  }
+
+  CXXMGMemberSet composePlus(const CXXMGMemberSet &L,
+                             const CXXMGMemberSet &R, SourceLocation OpLoc) {
+    CXXMGMemberSet Result;
+    Result.IsTrait = L.IsTrait || R.IsTrait;
+    Result.Members = L.Members;
+
+    for (const CXXMGMemberDescriptor &M : R.Members) {
+      bool Skip = false;
+      for (CXXMGMemberDescriptor &Existing : Result.Members) {
+        if (Existing.Name != M.Name)
+          continue;
+        if (!canCoexist(Ctx, Result.IsTrait, Existing, M)) {
+          S.Diag(M.Loc, diag::err_cxxmg_type_expr_conflicting_member) << M.Name;
+          S.Diag(Existing.Loc, diag::note_cxxmg_type_expr_previous_member);
+          S.Diag(OpLoc, diag::note_cxxmg_type_expr_in_result);
+          Result.Invalid = true;
+          return Result;
+        }
+        if (Result.IsTrait &&
+            Existing.Kind == CXXMGMemberKind::AssociatedTypeAny &&
+            M.Kind == CXXMGMemberKind::TypeAliasExact) {
+          Existing = M;
+          Skip = true;
+          break;
+        }
+        if (Result.IsTrait &&
+            ((Existing.Kind == CXXMGMemberKind::AssociatedTypeAny &&
+              M.Kind == CXXMGMemberKind::AssociatedTypeAny) ||
+             (Existing.Kind == CXXMGMemberKind::TypeAliasExact &&
+              M.Kind == CXXMGMemberKind::AssociatedTypeAny) ||
+             (Existing.Kind == CXXMGMemberKind::TypeAliasExact &&
+              M.Kind == CXXMGMemberKind::TypeAliasExact))) {
+          Skip = true;
+          break;
+        }
+      }
+      if (!Skip)
+        Result.Members.push_back(M);
+    }
+    return Result;
+  }
+
+  CXXMGMemberSet composeMinus(const CXXMGMemberSet &L,
+                              const CXXMGMemberSet &R, SourceLocation OpLoc) {
+    CXXMGMemberSet Result = L;
+    Result.IsTrait = L.IsTrait;
+    bool RemovedAny = false;
+    for (const CXXMGMemberDescriptor &Req : R.Members) {
+      auto NewEnd = llvm::remove_if(Result.Members, [&](const auto &Cand) {
+        return memberMatches(Ctx, Req, Cand);
+      });
+      RemovedAny |= NewEnd != Result.Members.end();
+      Result.Members.erase(NewEnd, Result.Members.end());
+    }
+    if (!RemovedAny)
+      S.Diag(OpLoc, diag::warn_cxxmg_type_expr_noop_subtraction);
+    return Result;
+  }
+
+  QualType synthesize(Scope *Sc, SourceLocation Loc,
+                      const CXXMGMemberSet &Set, Decl **OwnedType) {
+    TagTypeKind Kind = Set.IsTrait ? TagTypeKind::Trait : TagTypeKind::Struct;
+    auto *RD =
+        CXXRecordDecl::Create(Ctx, Kind, S.CurContext, Loc, Loc, nullptr);
+    RD->setImplicit();
+    RD->startDefinition();
+
+    SmallVector<Decl *, 16> Fields;
+    for (const CXXMGMemberDescriptor &M : Set.Members) {
+      Decl *D = cloneMember(RD, M);
+      if (!D)
+        continue;
+      D->setAccess(M.Access == AS_none ? AS_public : M.Access);
+      RD->addDecl(D);
+      if (isa<FieldDecl>(D))
+        Fields.push_back(D);
+    }
+
+    S.ActOnFields(Sc, Loc, RD, Fields, Loc, Loc, ParsedAttributesView());
+    S.CheckCompletedCXXClass(Sc, RD);
+    if (!RD->isInvalidDecl())
+      S.Consumer.HandleTagDeclDefinition(RD);
+
+    QualType Ty = Ctx.getCanonicalTagType(RD);
+    if (OwnedType)
+      *OwnedType = RD;
+    return Ty;
+  }
+
+  Decl *cloneMember(CXXRecordDecl *RD, const CXXMGMemberDescriptor &M) {
+    switch (M.Kind) {
+    case CXXMGMemberKind::Field: {
+      auto *FD = cast<FieldDecl>(M.SourceDecl);
+      InClassInitStyle InitStyle = FD->getInClassInitStyle();
+      auto *NewFD = FieldDecl::Create(Ctx, RD, FD->getBeginLoc(),
+                                      FD->getLocation(), FD->getIdentifier(),
+                                      FD->getType(), FD->getTypeSourceInfo(),
+                                      nullptr, FD->isMutable(), InitStyle);
+      if (Expr *Init = FD->getInClassInitializer())
+        NewFD->setInClassInitializer(Init);
+      return NewFD;
+    }
+    case CXXMGMemberKind::StaticData: {
+      auto *VD = cast<VarDecl>(M.SourceDecl);
+      auto *NewVD = VarDecl::Create(Ctx, RD, VD->getBeginLoc(),
+                                    VD->getLocation(), VD->getIdentifier(),
+                                    VD->getType(), VD->getTypeSourceInfo(),
+                                    SC_Static);
+      if (VD->isInline())
+        NewVD->setInlineSpecified();
+      if (VD->hasInit())
+        NewVD->setInit(VD->getInit());
+      return NewVD;
+    }
+    case CXXMGMemberKind::TypeAliasExact: {
+      auto *TD = cast<TypedefNameDecl>(M.SourceDecl);
+      if (auto *Alias = dyn_cast<TypeAliasDecl>(TD))
+        return TypeAliasDecl::Create(Ctx, RD, Alias->getBeginLoc(),
+                                     Alias->getLocation(),
+                                     Alias->getIdentifier(),
+                                     Alias->getTypeSourceInfo());
+      return TypedefDecl::Create(Ctx, RD, TD->getBeginLoc(),
+                                 TD->getLocation(), TD->getIdentifier(),
+                                 TD->getTypeSourceInfo());
+    }
+    case CXXMGMemberKind::AssociatedTypeAny: {
+      auto *TR = cast<TraitRequirementDecl>(M.SourceDecl);
+      return TraitRequirementDecl::Create(
+          Ctx, RD, TR->getKeywordLoc(), TR->getLocation(), TR->getIdentifier(),
+          TraitRequirementDecl::AssociatedTypeAny, nullptr);
+    }
+    case CXXMGMemberKind::StaticFunctionAnyReturn: {
+      auto *TR = cast<TraitRequirementDecl>(M.SourceDecl);
+      return TraitRequirementDecl::Create(
+          Ctx, RD, TR->getKeywordLoc(), TR->getLocation(), TR->getIdentifier(),
+          TraitRequirementDecl::StaticFunctionAnyReturn,
+          TR->getFunctionTypeInfo());
+    }
+    case CXXMGMemberKind::InstanceMethod:
+    case CXXMGMemberKind::StaticMethod: {
+      auto *MD = cast<CXXMethodDecl>(M.SourceDecl);
+      auto *NewMD = CXXMethodDecl::Create(
+          Ctx, RD, MD->getBeginLoc(), MD->getNameInfo(), MD->getType(),
+          MD->getTypeSourceInfo(), MD->isStatic() ? SC_Static : SC_None,
+          MD->UsesFPIntrin(), MD->isInlineSpecified(),
+          MD->getConstexprKind(), MD->getEndLoc(),
+          MD->getTrailingRequiresClause());
+      SmallVector<ParmVarDecl *, 8> Params;
+      for (ParmVarDecl *P : MD->parameters()) {
+        auto *NewP = ParmVarDecl::Create(
+            Ctx, NewMD, P->getBeginLoc(), P->getLocation(), P->getIdentifier(),
+            P->getType(), P->getTypeSourceInfo(), P->getStorageClass(),
+            P->getDefaultArg());
+        Params.push_back(NewP);
+      }
+      NewMD->setParams(Params);
+      if (MD->doesThisDeclarationHaveABody())
+        NewMD->setBody(MD->getBody());
+      return NewMD;
+    }
+    }
+    llvm_unreachable("unknown C++MG member kind");
+  }
+
+  bool evaluatePredicate(const ParsedCXXMGTypeExpr &TE, bool &Result) {
+    if (TE.K != ParsedCXXMGTypeExpr::Binary ||
+        (TE.Op != tok::ampamp && TE.Op != tok::pipepipe)) {
+      S.Diag(TE.BeginLoc,
+             diag::err_cxxmg_type_expr_invalid_operator_predicate_sema)
+          << getCXXMGOpName(TE.Op);
+      return false;
+    }
+
+    CXXMGMemberSet Req = buildSet(*TE.LHS);
+    CXXMGMemberSet Cand = buildSet(*TE.RHS);
+    if (Req.Invalid || Cand.Invalid)
+      return false;
+
+    if (TE.Op == tok::ampamp) {
+      Result = llvm::all_of(Req.Members, [&](const auto &R) {
+        return llvm::any_of(Cand.Members,
+                            [&](const auto &C) { return memberMatches(Ctx, R, C); });
+      });
+      return true;
+    }
+
+    Result = llvm::any_of(Req.Members, [&](const auto &R) {
+      return llvm::any_of(Cand.Members,
+                          [&](const auto &C) { return memberMatches(Ctx, R, C); });
+    });
+    return true;
+  }
+};
+
+} // namespace
+
+TypeResult Sema::ActOnCXXMGTypeAliasExpression(
+    Scope *CurScope, AccessSpecifier AS, MultiTemplateParamsArg TemplateParams,
+    SourceLocation UsingLoc, UnqualifiedId &Name,
+    const ParsedAttributesView &AttrList, const ParsedCXXMGTypeExpr &TE,
+    Decl **DeclFromDeclSpec) {
+  (void)AS;
+  (void)TemplateParams;
+  (void)Name;
+  (void)AttrList;
+
+  if (!getLangOpts().CPlusPlusMG) {
+    Diag(UsingLoc, diag::err_cxxmg_type_expr_requires_cxxmg);
+    return true;
+  }
+
+  CXXMGTypeExprSema Impl(*this);
+  CXXMGMemberSet Set = Impl.buildSet(TE);
+  if (Set.Invalid)
+    return true;
+
+  QualType Ty = Impl.synthesize(CurScope, UsingLoc, Set, DeclFromDeclSpec);
+  TypeSourceInfo *TSI = Context.getTrivialTypeSourceInfo(Ty, UsingLoc);
+  return CreateParsedType(Ty, TSI);
+}
+
+ExprResult Sema::ActOnCXXMGTypePredicateExpression(
+    Scope *S, const ParsedCXXMGTypeExpr &TE) {
+  if (!getLangOpts().CPlusPlusMG) {
+    Diag(TE.BeginLoc, diag::err_cxxmg_type_expr_requires_cxxmg);
+    return ExprError();
+  }
+
+  bool Result = false;
+  CXXMGTypeExprSema Impl(*this);
+  if (!Impl.evaluatePredicate(TE, Result))
+    return ExprError();
+
+  return CXXBoolLiteralExpr::Create(Context, Result, Context.BoolTy, TE.OpLoc);
+}
