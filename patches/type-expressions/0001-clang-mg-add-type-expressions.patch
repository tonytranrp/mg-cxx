diff --git a/clang/lib/Parse/ParseCXXMGTypeExpr.cpp b/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
new file mode 100644
index 000000000000..d36514d82a1b
--- /dev/null
+++ b/clang/lib/Parse/ParseCXXMGTypeExpr.cpp
@@ -0,0 +1,213 @@
+//===--- ParseCXXMGTypeExpr.cpp - C++MG Type Expressions -----------------===//
+//
+//  This file implements parsing for C++MG structural type expressions.
+//
+//===----------------------------------------------------------------------===//
+
+#include "clang/Basic/DiagnosticParse.h"
+#include "clang/Parse/Parser.h"
+#include "clang/Parse/RAIIObjectsForParser.h"
+#include "clang/Sema/EnterExpressionEvaluationContext.h"
+
+using namespace clang;
+
+static const char *getCXXMGTypeExprOperatorSpelling(tok::TokenKind K) {
+  if (const char *Spelling = tok::getPunctuatorSpelling(K))
+    return Spelling;
+  return tok::getTokenName(K);
+}
+
+static bool mayStartCXXMGTypePredicate(Parser &P) {
+  tok::TokenKind K = P.getCurToken().getKind();
+  if (K == tok::annot_typename || K == tok::kw_typename ||
+      K == tok::kw_decltype || K == tok::kw_struct || K == tok::kw_class ||
+      K == tok::kw_trait)
+    return true;
+
+  if (K == tok::identifier) {
+    tok::TokenKind Next = P.NextToken().getKind();
+    return Next == tok::plus || Next == tok::minus || Next == tok::ampamp ||
+           Next == tok::pipepipe;
+  }
+
+  if (K == tok::l_paren) {
+    tok::TokenKind First = P.GetLookAheadToken(1).getKind();
+    tok::TokenKind Second = P.GetLookAheadToken(2).getKind();
+    return First == tok::identifier &&
+           (Second == tok::plus || Second == tok::minus ||
+            Second == tok::ampamp || Second == tok::pipepipe);
+  }
+
+  return false;
+}
+
+bool Parser::isCXXMGTypeExprOperator(tok::TokenKind K,
+                                     bool AllowPredicates) const {
+  if (K == tok::plus || K == tok::minus)
+    return true;
+  if (AllowPredicates && (K == tok::ampamp || K == tok::pipepipe))
+    return true;
+  return false;
+}
+
+bool Parser::ParseCXXMGTypeExprPrimary(ParsedCXXMGTypeExpr &Out) {
+  if (Tok.is(tok::identifier) &&
+      NextToken().isOneOf(tok::plus, tok::minus, tok::ampamp,
+                          tok::pipepipe)) {
+    SourceLocation NameLoc = Tok.getLocation();
+    IdentifierInfo *II = Tok.getIdentifierInfo();
+    ParsedType Ty = Actions.getTypeName(*II, NameLoc, getCurScope());
+    if (!Ty)
+      return false;
+    ConsumeToken();
+
+    TypeSourceInfo *TSI = nullptr;
+    QualType QT = Actions.GetTypeFromParser(Ty, &TSI);
+    if (QT.isNull())
+      return false;
+    if (!TSI)
+      TSI = Actions.getASTContext().getTrivialTypeSourceInfo(QT, NameLoc);
+
+    Out = ParsedCXXMGTypeExpr();
+    Out.K = ParsedCXXMGTypeExpr::Operand;
+    Out.OperandType = Ty;
+    Out.OperandTSI = TSI;
+    Out.BeginLoc = NameLoc;
+    Out.EndLoc = NameLoc;
+    return true;
+  }
+
+  if (Tok.is(tok::l_paren)) {
+    SourceLocation LParen = ConsumeParen();
+    ParsedCXXMGTypeExpr Inner;
+    if (!ParseCXXMGTypeExprPrimary(Inner))
+      return false;
+    if (!ParseCXXMGTypeExprRHS(Inner, prec::Unknown,
+                               /*AllowPredicates=*/true))
+      return false;
+    if (Tok.isNot(tok::r_paren))
+      return false;
+    Inner.BeginLoc = LParen;
+    Inner.EndLoc = ConsumeParen();
+    Out = std::move(Inner);
+    return true;
+  }
+
+  SourceLocation Begin = Tok.getLocation();
+  SourceRange Range;
+  TypeResult TR = ParseTypeName(&Range);
+  if (TR.isInvalid() || !TR.get())
+    return false;
+
+  TypeSourceInfo *TSI = nullptr;
+  QualType QT = Actions.GetTypeFromParser(TR.get(), &TSI);
+  if (QT.isNull())
+    return false;
+  if (!TSI)
+    TSI = Actions.getASTContext().getTrivialTypeSourceInfo(QT, Begin);
+
+  Out = ParsedCXXMGTypeExpr();
+  Out.K = ParsedCXXMGTypeExpr::Operand;
+  Out.OperandType = TR.get();
+  Out.OperandTSI = TSI;
+  Out.BeginLoc = Range.getBegin().isValid() ? Range.getBegin() : Begin;
+  Out.EndLoc = Range.getEnd().isValid() ? Range.getEnd() : Begin;
+  return true;
+}
+
+bool Parser::ParseCXXMGTypeExprRHS(ParsedCXXMGTypeExpr &LHS,
+                                   prec::Level MinPrec,
+                                   bool AllowPredicates) {
+  while (true) {
+    tok::TokenKind Op = Tok.getKind();
+    if (!isCXXMGTypeExprOperator(Op, AllowPredicates))
+      return true;
+
+    prec::Level OpPrec =
+        getBinOpPrecedence(Op, GreaterThanIsOperator, getLangOpts().CPlusPlus11);
+    if (OpPrec < MinPrec)
+      return true;
+
+    if (!AllowPredicates && (Op == tok::ampamp || Op == tok::pipepipe)) {
+      Diag(Tok.getLocation(), diag::err_cxxmg_type_expr_invalid_operator_alias)
+          << getCXXMGTypeExprOperatorSpelling(Op);
+      return false;
+    }
+
+    SourceLocation OpLoc = ConsumeToken();
+    ParsedCXXMGTypeExpr RHS;
+    if (!ParseCXXMGTypeExprPrimary(RHS))
+      return false;
+
+    tok::TokenKind NextOp = Tok.getKind();
+    prec::Level NextPrec = isCXXMGTypeExprOperator(NextOp, AllowPredicates)
+                               ? getBinOpPrecedence(NextOp,
+                                                    GreaterThanIsOperator,
+                                                    getLangOpts().CPlusPlus11)
+                               : prec::Unknown;
+    if (NextPrec > OpPrec &&
+        !ParseCXXMGTypeExprRHS(RHS, static_cast<prec::Level>(OpPrec + 1),
+                               AllowPredicates))
+      return false;
+
+    auto Node = std::make_unique<ParsedCXXMGTypeExpr>();
+    Node->K = ParsedCXXMGTypeExpr::Binary;
+    Node->Op = Op;
+    Node->OpLoc = OpLoc;
+    Node->BeginLoc = LHS.BeginLoc;
+    Node->EndLoc = RHS.EndLoc;
+    Node->SawTypeExprOperator = true;
+    Node->LHS = std::make_unique<ParsedCXXMGTypeExpr>(std::move(LHS));
+    Node->RHS = std::make_unique<ParsedCXXMGTypeExpr>(std::move(RHS));
+    LHS = std::move(*Node);
+  }
+}
+
+bool Parser::TryParseCXXMGTypeExpression(ParsedCXXMGTypeExpr &Out,
+                                         bool AllowPredicates,
+                                         bool RequireTypeProducingResult) {
+  if (!getLangOpts().CPlusPlusMG)
+    return false;
+
+  if (!ParseCXXMGTypeExprPrimary(Out))
+    return false;
+  if (!ParseCXXMGTypeExprRHS(Out, prec::Unknown, AllowPredicates))
+    return false;
+
+  if (RequireTypeProducingResult && Out.K == ParsedCXXMGTypeExpr::Binary &&
+      (Out.Op == tok::ampamp || Out.Op == tok::pipepipe)) {
+    Diag(Out.OpLoc, diag::err_cxxmg_type_expr_invalid_operator_alias)
+        << getCXXMGTypeExprOperatorSpelling(Out.Op);
+    return false;
+  }
+
+  return true;
+}
+
+ExprResult Parser::TryParseCXXMGTypePredicateExpression() {
+  if (!getLangOpts().CPlusPlusMG)
+    return ExprEmpty();
+
+  if (!mayStartCXXMGTypePredicate(*this))
+    return ExprEmpty();
+
+  TentativeParsingAction TPA(*this);
+  ParsedCXXMGTypeExpr TE;
+  if (!TryParseCXXMGTypeExpression(TE, /*AllowPredicates=*/true,
+                                   /*RequireTypeProducingResult=*/false) ||
+      !TE.SawTypeExprOperator) {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+
+  if (TE.K != ParsedCXXMGTypeExpr::Binary ||
+      (TE.Op != tok::ampamp && TE.Op != tok::pipepipe)) {
+    TPA.Revert();
+    return ExprEmpty();
+  }
+
+  TPA.Commit();
+  EnterExpressionEvaluationContext Unevaluated(
+      Actions, Sema::ExpressionEvaluationContext::Unevaluated);
+  return Actions.ActOnCXXMGTypePredicateExpression(getCurScope(), TE);
+}
