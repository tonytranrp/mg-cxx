+
+trait AnyType {
+  using type;
+};
+
+trait ExactType {
+  using type = int;
+};
+
+struct A {
+  using type = int;
+};
+
+struct B {
+  using type = bool;
+};
+
+static_assert(AnyType && A);
+static_assert(ExactType && A);
+static constexpr bool exactB = ExactType && B;
+static_assert(!exactB);
