+static CXXMGTypeExprOpcode translateTokenToCXXMGOpcode(tok::TokenKind K) {
+  switch (K) {
+  case tok::plus:
+    return CXXMGTypeExprOpcode::Add;
+  case tok::minus:
+    return CXXMGTypeExprOpcode::Sub;
+  case tok::ampamp:
+    return CXXMGTypeExprOpcode::All;
+  case tok::pipepipe:
+    return CXXMGTypeExprOpcode::Any;
+  default:
+    llvm_unreachable("not a C++MG type-expression operator");
+  }
+}
