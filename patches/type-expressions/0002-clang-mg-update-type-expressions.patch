   /// Recursively visit an attribute, by dispatching to
   /// Traverse*Attr() based on the argument's dynamic type.
@@ -750,6 +752,18 @@ bool RecursiveASTVisitor<Derived>::TraverseTypeLoc(TypeLoc TL,
   return true;
 }
 
+template <typename Derived>
+bool RecursiveASTVisitor<Derived>::TraverseCXXMGTypeExprNode(
+    CXXMGTypeExprNode *Node) {
+  if (!Node)
+    return true;
+  if (Node->isOperand())
+    return TraverseTypeLoc(Node->getOperandTypeSourceInfo()->getTypeLoc());
+  TRY_TO(TraverseCXXMGTypeExprNode(Node->getLHS()));
+  TRY_TO(TraverseCXXMGTypeExprNode(Node->getRHS()));
+  return true;
+}
