+CXXMGTypeExprNode *ASTRecordReader::readCXXMGTypeExprNodeRef() {
+  if (!readInt())
+    return nullptr;
+
+  auto Kind = static_cast<CXXMGTypeExprNode::NodeKind>(readInt());
+  SourceLocation Begin = readSourceLocation();
+  SourceLocation End = readSourceLocation();
+  if (Kind == CXXMGTypeExprNode::Operand)
+    return CXXMGTypeExprNode::CreateOperand(
+        getContext(), readTypeSourceInfo(), SourceRange(Begin, End));
+
+  auto Opcode = static_cast<CXXMGTypeExprOpcode>(readInt());
+  SourceLocation OpLoc = readSourceLocation();
+  CXXMGTypeExprNode *LHS = readCXXMGTypeExprNodeRef();
+  CXXMGTypeExprNode *RHS = readCXXMGTypeExprNodeRef();
+  return CXXMGTypeExprNode::CreateBinary(getContext(), Opcode, LHS, RHS, OpLoc,
+                                         SourceRange(Begin, End));
+}
