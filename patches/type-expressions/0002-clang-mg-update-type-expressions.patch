+class CXXMGTypeExprType final : public Type, public llvm::FoldingSetNode {
+  friend class ASTContext;
+
+  CXXMGTypeExprNode *ExprNode = nullptr;
+
+  CXXMGTypeExprType(QualType CanonicalType, CXXMGTypeExprNode *ExprNode,
+                    TypeDependence Dependence)
+      : Type(CXXMGTypeExpr, CanonicalType, Dependence), ExprNode(ExprNode) {}
+
+public:
+  CXXMGTypeExprNode *getTypeExprNode() const { return ExprNode; }
+
+  bool isSugared() const { return false; }
+  QualType desugar() const { return QualType(this, 0); }
+
+  void Profile(llvm::FoldingSetNodeID &ID) { Profile(ID, ExprNode); }
+  static void Profile(llvm::FoldingSetNodeID &ID,
+                      CXXMGTypeExprNode *ExprNode);
+
+  static bool classof(const Type *T) {
+    return T->getTypeClass() == CXXMGTypeExpr;
+  }
+};
