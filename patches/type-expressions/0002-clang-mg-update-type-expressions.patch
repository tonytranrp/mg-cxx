+QualType
+ASTContext::getCXXMGTypeExprType(CXXMGTypeExprNode *ExprNode) const {
+  llvm::FoldingSetNodeID ID;
+  CXXMGTypeExprType::Profile(ID, ExprNode);
+  void *InsertPos = nullptr;
+  if (auto *T = CXXMGTypeExprTypes.FindNodeOrInsertPos(ID, InsertPos))
+    return QualType(T, 0);
+
+  TypeDependence Dependence =
+      TypeDependence::Dependent | TypeDependence::Instantiation;
+  if (ExprNode && ExprNode->containsUnexpandedParameterPack())
+    Dependence |= TypeDependence::UnexpandedPack;
+
+  auto *T = new (*this, TypeAlignment)
+      CXXMGTypeExprType(QualType(), ExprNode, Dependence);
+  Types.push_back(T);
+  CXXMGTypeExprTypes.InsertNode(T, InsertPos);
+  return QualType(T, 0);
+}
