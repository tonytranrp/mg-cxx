+    return NewTy;
+  }
+
+  Decl *OwnedType = nullptr;
+  QualType NewTy = getSema().BuildCXXMGTypeExpressionType(
+      /*S=*/nullptr, NewNode, NewNode->getBeginLoc(), &OwnedType);
+  if (NewTy.isNull())
+    return QualType();
+
+  TypeSourceInfo *TSI =
+      getSema().Context.getTrivialTypeSourceInfo(NewTy, NewNode->getBeginLoc());
+  TLB.pushFullCopy(TSI->getTypeLoc());
+  return NewTy;
