+void ASTRecordWriter::AddCXXMGTypeExprNode(CXXMGTypeExprNode *Node) {
+  Record->push_back(Node ? 1 : 0);
+  if (!Node)
+    return;
+
+  Record->push_back(Node->getKind());
+  AddSourceLocation(Node->getBeginLoc());
+  AddSourceLocation(Node->getEndLoc());
+  if (Node->isOperand()) {
+    AddTypeSourceInfo(Node->getOperandTypeSourceInfo());
+    return;
+  }
+
+  Record->push_back(static_cast<unsigned>(Node->getOpcode()));
+  AddSourceLocation(Node->getOperatorLoc());
+  AddCXXMGTypeExprNode(Node->getLHS());
+  AddCXXMGTypeExprNode(Node->getRHS());
+}
