+static void printCXXMGTypeExprNode(const CXXMGTypeExprNode *Node,
+                                   raw_ostream &OS,
+                                   const PrintingPolicy &Policy) {
+  if (!Node)
+    return;
+  if (Node->isOperand()) {
+    Node->getOperandTypeSourceInfo()->getType().print(OS, Policy);
+    return;
+  }
+  OS << '(';
+  printCXXMGTypeExprNode(Node->getLHS(), OS, Policy);
+  OS << ' ' << getCXXMGTypeExprOpcodeSpelling(Node->getOpcode()) << ' ';
+  printCXXMGTypeExprNode(Node->getRHS(), OS, Policy);
+  OS << ')';
+}
