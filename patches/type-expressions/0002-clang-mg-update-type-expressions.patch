+QualType Sema::BuildCXXMGTypeExpressionType(Scope *S, CXXMGTypeExprNode *TE,
+                                            SourceLocation Loc,
+                                            Decl **OwnedType) {
+  if (!TE)
+    return QualType();
+
+  if (TE->isDependent() || TE->isInstantiationDependent())
+    return Context.getCXXMGTypeExprType(TE);
+
+  CXXMGTypeExprSema Impl(*this);
+  CXXMGMemberSet Set = Impl.buildSet(TE);
+  if (Set.Invalid)
+    return QualType();
+
+  return Impl.synthesize(S, Loc, Set, OwnedType);
+}
