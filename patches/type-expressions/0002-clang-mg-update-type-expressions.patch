+//===- CXXMGTypeExpr.h - C++MG type-expression AST nodes --------*- C++ -*-===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+
+#ifndef LLVM_CLANG_AST_CXXMGTYPEEXPR_H
+#define LLVM_CLANG_AST_CXXMGTYPEEXPR_H
+
+#include "clang/Basic/SourceLocation.h"
+#include "llvm/Support/Casting.h"
+#include <cassert>
+
+namespace llvm {
+class FoldingSetNodeID;
+} // namespace llvm
+
+namespace clang {
+
+class ASTContext;
+class TypeSourceInfo;
+
+enum class CXXMGTypeExprOpcode : unsigned {
+  Add,
+  Sub,
+  All,
+  Any
+};
+
+const char *getCXXMGTypeExprOpcodeSpelling(CXXMGTypeExprOpcode Op);
+
+class CXXMGTypeExprNode {
+public:
+  enum NodeKind : unsigned {
+    Operand,
+    Binary
+  };
+
+private:
+  NodeKind Kind;
+  TypeSourceInfo *OperandTSI = nullptr;
+  CXXMGTypeExprOpcode Opcode = CXXMGTypeExprOpcode::Add;
+  CXXMGTypeExprNode *LHS = nullptr;
+  CXXMGTypeExprNode *RHS = nullptr;
+  SourceLocation OpLoc;
+  SourceRange Range;
+  bool Dependent = false;
+  bool InstantiationDependent = false;
+  bool ContainsUnexpandedParameterPack = false;
+
+  CXXMGTypeExprNode(TypeSourceInfo *OperandTSI, SourceRange Range,
+                    bool Dependent, bool InstantiationDependent,
+                    bool ContainsUnexpandedParameterPack);
+  CXXMGTypeExprNode(CXXMGTypeExprOpcode Opcode, CXXMGTypeExprNode *LHS,
+                    CXXMGTypeExprNode *RHS, SourceLocation OpLoc,
+                    SourceRange Range, bool Dependent,
+                    bool InstantiationDependent,
+                    bool ContainsUnexpandedParameterPack);
+
+public:
+  static CXXMGTypeExprNode *CreateOperand(ASTContext &Ctx,
+                                          TypeSourceInfo *OperandTSI,
+                                          SourceRange Range);
+  static CXXMGTypeExprNode *CreateBinary(ASTContext &Ctx,
+                                         CXXMGTypeExprOpcode Opcode,
+                                         CXXMGTypeExprNode *LHS,
+                                         CXXMGTypeExprNode *RHS,
+                                         SourceLocation OpLoc,
+                                         SourceRange Range);
+
+  NodeKind getKind() const { return Kind; }
+  bool isOperand() const { return Kind == Operand; }
+  bool isBinary() const { return Kind == Binary; }
+
+  TypeSourceInfo *getOperandTypeSourceInfo() const {
+    assert(isOperand());
+    return OperandTSI;
+  }
+
+  CXXMGTypeExprOpcode getOpcode() const {
+    assert(isBinary());
+    return Opcode;
+  }
+
+  CXXMGTypeExprNode *getLHS() const {
+    assert(isBinary());
+    return LHS;
+  }
+
+  CXXMGTypeExprNode *getRHS() const {
+    assert(isBinary());
+    return RHS;
+  }
+
+  SourceLocation getOperatorLoc() const { return OpLoc; }
+  SourceRange getSourceRange() const { return Range; }
+  SourceLocation getBeginLoc() const { return Range.getBegin(); }
+  SourceLocation getEndLoc() const { return Range.getEnd(); }
+
+  bool isDependent() const { return Dependent; }
+  bool isInstantiationDependent() const { return InstantiationDependent; }
+  bool containsUnexpandedParameterPack() const {
+    return ContainsUnexpandedParameterPack;
+  }
+
+  void Profile(llvm::FoldingSetNodeID &ID) const;
+};
+
+} // namespace clang
+
+#endif
