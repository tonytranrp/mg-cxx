+#include "clang/AST/CXXMGTypeExpr.h"
+#include "clang/AST/ASTContext.h"
+#include "clang/AST/Type.h"
+#include "llvm/ADT/FoldingSet.h"
+#include "llvm/Support/ErrorHandling.h"
+
+using namespace clang;
+
+const char *clang::getCXXMGTypeExprOpcodeSpelling(CXXMGTypeExprOpcode Op) {
+  switch (Op) {
+  case CXXMGTypeExprOpcode::Add:
+    return "+";
+  case CXXMGTypeExprOpcode::Sub:
+    return "-";
+  case CXXMGTypeExprOpcode::All:
+    return "&&";
+  case CXXMGTypeExprOpcode::Any:
+    return "||";
+  }
+  llvm_unreachable("unknown C++MG type-expression opcode");
+}
+
+CXXMGTypeExprNode::CXXMGTypeExprNode(
+    TypeSourceInfo *OperandTSI, SourceRange Range, bool Dependent,
+    bool InstantiationDependent, bool ContainsUnexpandedParameterPack)
+    : Kind(Operand), OperandTSI(OperandTSI), Range(Range),
+      Dependent(Dependent), InstantiationDependent(InstantiationDependent),
+      ContainsUnexpandedParameterPack(ContainsUnexpandedParameterPack) {}
+
+CXXMGTypeExprNode::CXXMGTypeExprNode(
+    CXXMGTypeExprOpcode Opcode, CXXMGTypeExprNode *LHS,
+    CXXMGTypeExprNode *RHS, SourceLocation OpLoc, SourceRange Range,
+    bool Dependent, bool InstantiationDependent,
+    bool ContainsUnexpandedParameterPack)
+    : Kind(Binary), Opcode(Opcode), LHS(LHS), RHS(RHS), OpLoc(OpLoc),
+      Range(Range), Dependent(Dependent),
+      InstantiationDependent(InstantiationDependent),
+      ContainsUnexpandedParameterPack(ContainsUnexpandedParameterPack) {}
+
+CXXMGTypeExprNode *
+CXXMGTypeExprNode::CreateOperand(ASTContext &Ctx, TypeSourceInfo *OperandTSI,
+                                 SourceRange Range) {
+  QualType T = OperandTSI ? OperandTSI->getType() : QualType();
+  bool Dep = !T.isNull() && T->isDependentType();
+  bool InstDep = !T.isNull() && T->isInstantiationDependentType();
+  bool Packs = !T.isNull() && T->containsUnexpandedParameterPack();
+  void *Mem = Ctx.Allocate(sizeof(CXXMGTypeExprNode),
+                           alignof(CXXMGTypeExprNode));
+  return new (Mem) CXXMGTypeExprNode(OperandTSI, Range, Dep, InstDep, Packs);
+}
+
+CXXMGTypeExprNode *CXXMGTypeExprNode::CreateBinary(
+    ASTContext &Ctx, CXXMGTypeExprOpcode Opcode, CXXMGTypeExprNode *LHS,
+    CXXMGTypeExprNode *RHS, SourceLocation OpLoc, SourceRange Range) {
+  bool Dep = (LHS && LHS->isDependent()) || (RHS && RHS->isDependent());
+  bool InstDep = (LHS && LHS->isInstantiationDependent()) ||
+                 (RHS && RHS->isInstantiationDependent());
+  bool Packs = (LHS && LHS->containsUnexpandedParameterPack()) ||
+               (RHS && RHS->containsUnexpandedParameterPack());
+  void *Mem = Ctx.Allocate(sizeof(CXXMGTypeExprNode),
+                           alignof(CXXMGTypeExprNode));
+  return new (Mem) CXXMGTypeExprNode(Opcode, LHS, RHS, OpLoc, Range, Dep,
+                                     InstDep, Packs);
+}
+
+void CXXMGTypeExprNode::Profile(llvm::FoldingSetNodeID &ID) const {
+  ID.AddInteger(getKind());
+  if (isOperand()) {
+    QualType T = OperandTSI ? OperandTSI->getType() : QualType();
+    ID.AddPointer(T.getAsOpaquePtr());
+    return;
+  }
+  ID.AddInteger(static_cast<unsigned>(Opcode));
+  LHS->Profile(ID);
+  RHS->Profile(ID);
+}
