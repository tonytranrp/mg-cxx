+#ifndef LLVM_CLANG_AST_EXPRCXXMG_H
+#define LLVM_CLANG_AST_EXPRCXXMG_H
+
+#include "clang/AST/CXXMGTypeExpr.h"
+#include "clang/AST/Expr.h"
+
+namespace clang {
+
+class CXXMGTypeCheckExpr final : public Expr {
+  CXXMGTypeExprNode *ExprNode = nullptr;
+
+public:
+  CXXMGTypeCheckExpr(QualType BoolTy, CXXMGTypeExprNode *ExprNode,
+                     ExprDependence Dependence)
+      : Expr(CXXMGTypeCheckExprClass, BoolTy, VK_PRValue, OK_Ordinary),
+        ExprNode(ExprNode) {
+    setDependence(Dependence);
+  }
+
+  explicit CXXMGTypeCheckExpr(EmptyShell Empty)
+      : Expr(CXXMGTypeCheckExprClass, Empty) {}
+
+  static CXXMGTypeCheckExpr *Create(ASTContext &Ctx,
+                                    CXXMGTypeExprNode *ExprNode);
+  static CXXMGTypeCheckExpr *CreateEmpty(ASTContext &Ctx);
+
+  CXXMGTypeExprNode *getTypeExprNode() const { return ExprNode; }
+  void setTypeExprNode(CXXMGTypeExprNode *Node) { ExprNode = Node; }
+
+  SourceLocation getBeginLoc() const LLVM_READONLY {
+    return ExprNode ? ExprNode->getBeginLoc() : SourceLocation();
+  }
+
+  SourceLocation getEndLoc() const LLVM_READONLY {
+    return ExprNode ? ExprNode->getEndLoc() : SourceLocation();
+  }
+
+  SourceLocation getExprLoc() const LLVM_READONLY {
+    if (!ExprNode)
+      return SourceLocation();
+    return ExprNode->isBinary() ? ExprNode->getOperatorLoc()
+                                : ExprNode->getBeginLoc();
+  }
+
+  child_range children() {
+    return child_range(child_iterator(), child_iterator());
+  }
+
+  const_child_range children() const {
+    return const_child_range(const_child_iterator(), const_child_iterator());
+  }
+
+  static bool classof(const Stmt *T) {
+    return T->getStmtClass() == CXXMGTypeCheckExprClass;
+  }
+};
+
+} // namespace clang
+
+#endif
