+CXXMGTypeExprNode *
+Sema::BuildCXXMGTypeExprNode(Scope *S, const ParsedCXXMGTypeExpr &TE) {
+  (void)S;
+  if (TE.K == ParsedCXXMGTypeExpr::Operand)
+    return CXXMGTypeExprNode::CreateOperand(
+        Context, TE.OperandTSI, SourceRange(TE.BeginLoc, TE.EndLoc));
+
+  CXXMGTypeExprNode *LHS = BuildCXXMGTypeExprNode(S, *TE.LHS);
+  CXXMGTypeExprNode *RHS = BuildCXXMGTypeExprNode(S, *TE.RHS);
+  if (!LHS || !RHS)
+    return nullptr;
+
+  return CXXMGTypeExprNode::CreateBinary(
+      Context, translateTokenToCXXMGOpcode(TE.Op), LHS, RHS, TE.OpLoc,
+      SourceRange(TE.BeginLoc, TE.EndLoc));
+}
