+ExprResult Sema::BuildCXXMGTypePredicateExpr(CXXMGTypeExprNode *TE) {
+  if (!TE)
+    return ExprError();
+
+  if (TE->isDependent() || TE->isInstantiationDependent())
+    return CXXMGTypeCheckExpr::Create(Context, TE);
+
+  bool Result = false;
+  CXXMGTypeExprSema Impl(*this);
+  if (!Impl.evaluatePredicate(TE, Result))
+    return ExprError();
+
+  return CXXBoolLiteralExpr::Create(Context, Result, Context.BoolTy,
+                                    TE->getOperatorLoc());
+}
