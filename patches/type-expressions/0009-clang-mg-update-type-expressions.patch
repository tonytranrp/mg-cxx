diff --git a/clang/test/CXXMG/type-expressions/type-predicate-constexpr.cpp b/clang/test/CXXMG/type-expressions/type-predicate-constexpr.cpp
new file mode 100644
index 000000000000..342842f64d1a
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-predicate-constexpr.cpp
@@ -0,0 +1,53 @@
+// RUN: %clang_cc1 -std=c++20 -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+trait has_value {
+  int value;
+};
+
+struct with_value {
+  int value;
+};
+
+struct without_value {};
+
+constexpr bool direct_true = has_value && with_value;
+constexpr bool direct_false = has_value && without_value;
+
+static_assert(direct_true);
+static_assert(!direct_false);
+
+template <typename T>
+constexpr bool check_with_alias() {
+  using backend_t = T;
+  constexpr bool is_gen = has_value && backend_t;
+  return is_gen;
+}
+
+static_assert(check_with_alias<with_value>());
+static_assert(!check_with_alias<without_value>());
+
+template <typename T>
+int check_if_constexpr() {
+  using backend_t = T;
+  constexpr bool is_gen = has_value && backend_t;
+
+  if constexpr (is_gen) {
+    return 1;
+  } else {
+    return 0;
+  }
+}
+
+static_assert(check_if_constexpr<with_value>() == 1);
+static_assert(check_if_constexpr<without_value>() == 0);
+
+template <typename T>
+void check_static_local() {
+  using backend_t = T;
+  static constexpr bool is_gen = has_value && backend_t;
+  static_assert(is_gen == (has_value && T));
+}
+
+template void check_static_local<with_value>();
+template void check_static_local<without_value>();
