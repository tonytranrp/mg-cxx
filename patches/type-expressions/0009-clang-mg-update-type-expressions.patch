diff --git a/clang/lib/Sema/TreeTransform.h b/clang/lib/Sema/TreeTransform.h
index 060e685b2bd4..64ff7db5d486 100644
--- a/clang/lib/Sema/TreeTransform.h
+++ b/clang/lib/Sema/TreeTransform.h
@@ -14783,7 +14783,21 @@ TreeTransform<Derived>::TransformCXXMGTypeCheckExpr(CXXMGTypeCheckExpr *E) {
       getDerived().TransformCXXMGTypeExprNode(E->getTypeExprNode());
   if (!NewNode)
     return ExprError();
-  return getSema().BuildCXXMGTypePredicateExpr(NewNode);
+  ExprResult R = getSema().BuildCXXMGTypePredicateExpr(NewNode);
+
+#ifndef NDEBUG
+  if (!R.isInvalid() && !NewNode->isDependent() &&
+      !NewNode->isInstantiationDependent()) {
+    auto *Check = dyn_cast<CXXMGTypeCheckExpr>(R.get());
+    assert(Check && "C++MG predicate should rebuild as CXXMGTypeCheckExpr");
+    assert(Check->hasKnownValue() &&
+           "non-dependent C++MG predicate should have known value");
+    assert(!Check->isValueDependent() &&
+           "known C++MG predicate should not be value-dependent");
+  }
+#endif
+
+  return R;
 }
 
