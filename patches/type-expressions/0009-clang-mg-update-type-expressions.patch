diff --git a/clang/include/clang/AST/ExprCXXMG.h b/clang/include/clang/AST/ExprCXXMG.h
index 32a66d385110..cae1e9bcffde 100644
--- a/clang/include/clang/AST/ExprCXXMG.h
+++ b/clang/include/clang/AST/ExprCXXMG.h
@@ -16,12 +16,24 @@ namespace clang {
 
 class CXXMGTypeCheckExpr final : public Expr {
   CXXMGTypeExprNode *ExprNode = nullptr;
+  bool HasKnownValue = false;
+  bool KnownValue = false;
 
 public:
+  // CXXMGTypeCheckExpr represents a C++MG structural type predicate.
+  //
+  // The expression always has type bool. If the underlying type-expression tree
+  // is dependent, the expression is value-/instantiation-dependent and has no
+  // cached value. Once Sema can evaluate the predicate, the expression stores
+  // the result in KnownValue and is no longer value-dependent. The constant
+  // evaluator must not recompute the predicate; it only consumes the cached
+  // value.
   CXXMGTypeCheckExpr(QualType BoolTy, CXXMGTypeExprNode *ExprNode,
-                     ExprDependence Dependence)
+                     ExprDependence Dependence, bool HasKnownValue = false,
+                     bool KnownValue = false)
       : Expr(CXXMGTypeCheckExprClass, BoolTy, VK_PRValue, OK_Ordinary),
-        ExprNode(ExprNode) {
+        ExprNode(ExprNode), HasKnownValue(HasKnownValue),
+        KnownValue(KnownValue) {
     setDependence(Dependence);
   }
 
@@ -30,11 +42,31 @@ public:
 
   static CXXMGTypeCheckExpr *Create(ASTContext &Ctx,
                                     CXXMGTypeExprNode *ExprNode);
+  static CXXMGTypeCheckExpr *CreateResolved(ASTContext &Ctx,
+                                            CXXMGTypeExprNode *ExprNode,
+                                            bool Value);
   static CXXMGTypeCheckExpr *CreateEmpty(ASTContext &Ctx);
 
   CXXMGTypeExprNode *getTypeExprNode() const { return ExprNode; }
   void setTypeExprNode(CXXMGTypeExprNode *Node) { ExprNode = Node; }
 
+  bool hasKnownValue() const { return HasKnownValue; }
+
+  bool getKnownValue() const {
+    assert(HasKnownValue && "CXXMGTypeCheckExpr has no known value");
+    return KnownValue;
+  }
+
+  void setKnownValue(bool Value) {
+    HasKnownValue = true;
+    KnownValue = Value;
+  }
+
+  void clearKnownValue() {
+    HasKnownValue = false;
+    KnownValue = false;
+  }
+
   SourceLocation getBeginLoc() const LLVM_READONLY {
     return ExprNode ? ExprNode->getBeginLoc() : SourceLocation();
   }
