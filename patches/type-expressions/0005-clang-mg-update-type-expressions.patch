+// RUN: %clang_cc1 -std=c++14 -fcxxmg -fsyntax-only -verify %s
 
 // expected-no-diagnostics
 
diff --git a/clang/test/CXXMG/type-expressions/type-expr-do-not-hijack-function-style-construction.cpp b/clang/test/CXXMG/type-expressions/type-expr-do-not-hijack-function-style-construction.cpp
new file mode 100644
index 000000000000..19cbeec14531
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-expr-do-not-hijack-function-style-construction.cpp
@@ -0,0 +1,21 @@
+// RUN: %clang_cc1 -std=c++14 -fcxxmg -fcxx-exceptions -fexceptions -fsyntax-only -verify %s
+
+// expected-no-diagnostics
+
+class failure {
+public:
+  explicit failure(const char *);
+};
+
+void test_throw() {
+  const char *_Msg = "badbit";
+  throw failure(_Msg);
+}
+
+struct shared_ptr {
+  explicit shared_ptr(int);
+};
+
+void test_function_style_construction(int _Right) {
+  (void) shared_ptr(_Right);
+}
diff --git a/clang/test/CXXMG/type-expressions/type-expr-predicate-no-typename-fallback.cpp b/clang/test/CXXMG/type-expressions/type-expr-predicate-no-typename-fallback.cpp
new file mode 100644
index 000000000000..f28d1db01507
