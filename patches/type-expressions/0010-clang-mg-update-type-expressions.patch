--- a/clang/lib/AST/ASTStructuralEquivalence.cpp
+++ b/clang/lib/AST/ASTStructuralEquivalence.cpp
@@ -170,6 +170,24 @@ namespace {
 class StmtComparer {
   StructuralEquivalenceContext &Context;
 
+  bool IsCXXMGTypeExprNodeEquivalent(const CXXMGTypeExprNode *N1,
+                                     const CXXMGTypeExprNode *N2) {
+    if (static_cast<bool>(N1) != static_cast<bool>(N2))
+      return false;
+    if (!N1)
+      return true;
+    if (N1->getKind() != N2->getKind())
+      return false;
+    if (N1->isOperand())
+      return IsStructurallyEquivalent(
+          Context, N1->getOperandTypeSourceInfo()->getType(),
+          N2->getOperandTypeSourceInfo()->getType());
+    if (N1->getOpcode() != N2->getOpcode())
+      return false;
+    return IsCXXMGTypeExprNodeEquivalent(N1->getLHS(), N2->getLHS()) &&
+           IsCXXMGTypeExprNodeEquivalent(N1->getRHS(), N2->getRHS());
+  }
+
   // IsStmtEquivalent overloads. Each overload compares a specific statement
   // and only has to compare the data that is specific to the specific statement
   // class. Should only be called from TraverseStmt.
@@ -414,7 +432,8 @@ class StmtComparer {
     if (E1->hasKnownValue() && E1->getKnownValue() != E2->getKnownValue())
       return false;
 
-    return true;
+    return IsCXXMGTypeExprNodeEquivalent(E1->getTypeExprNode(),
+                                         E2->getTypeExprNode());
   }
 
   /// End point of the traversal chain.
