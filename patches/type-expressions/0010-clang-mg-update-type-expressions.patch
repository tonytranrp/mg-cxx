+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+// expected-no-diagnostics
+
+namespace std {
+  template <class T>
+  T declval();
+
+  template <class It, class T>
+  It find(It, It, const T&);
+
+  template <class T, unsigned N>
+  T *end(T (&)[N]);
+}
+
+template <class...>
+using __void_t = void;
+
+template <class _Tp, class _Up, class = void>
+struct swappable_test {};
+
+template <class _Tp, class _Up>
+struct swappable_test<
+    _Tp,
+    _Up,
+    __void_t<decltype(std::declval<_Tp>()),
+             decltype(std::declval<_Up>())>> {};
+
+struct __num_get_base {
+  static const int __num_get_buf_sz = 32;
+};
+
+unsigned global_array[__num_get_base::__num_get_buf_sz];
+
+struct ordering {
+  static const int less = -1;
+  static const int greater = 1;
+};
+
+constexpr int choose(bool b) {
+  return b ? ordering::less : ordering::greater;
+}
+
+void use_find(char *first, char *last, char value) {
+  char *ret = std::find(first, last, value);
+  (void)ret;
+}
