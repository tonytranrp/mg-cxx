+bool UnnamedLocalNoLinkageFinder::VisitCXXMGTypeExprNode(
+    const CXXMGTypeExprNode *Node) {
+  if (!Node)
+    return false;
+
+  if (Node->isOperand())
+    return Visit(Node->getOperandTypeSourceInfo()->getType());
+
+  return VisitCXXMGTypeExprNode(Node->getLHS()) ||
+         VisitCXXMGTypeExprNode(Node->getRHS());
+}
+
+bool UnnamedLocalNoLinkageFinder::VisitCXXMGTypeExprType(
+    const CXXMGTypeExprType *T) {
+  return VisitCXXMGTypeExprNode(T->getTypeExprNode());
+}
