+static Expected<CXXMGTypeExprNode *>
+ImportCXXMGTypeExprNode(ASTImporter &Importer, ASTContext &ToContext,
+                        CXXMGTypeExprNode *Node) {
+  if (!Node)
+    return nullptr;
+
+  ExpectedSLoc BeginOrErr = Importer.Import(Node->getBeginLoc());
+  if (!BeginOrErr)
+    return BeginOrErr.takeError();
+
+  ExpectedSLoc EndOrErr = Importer.Import(Node->getEndLoc());
+  if (!EndOrErr)
+    return EndOrErr.takeError();
+
+  if (Node->isOperand()) {
+    Expected<TypeSourceInfo *> TSIOrErr =
+        Importer.Import(Node->getOperandTypeSourceInfo());
+    if (!TSIOrErr)
+      return TSIOrErr.takeError();
+
+    return CXXMGTypeExprNode::CreateOperand(
+        ToContext, *TSIOrErr, SourceRange(*BeginOrErr, *EndOrErr));
+  }
+
+  ExpectedSLoc OpLocOrErr = Importer.Import(Node->getOperatorLoc());
+  if (!OpLocOrErr)
+    return OpLocOrErr.takeError();
+
+  Expected<CXXMGTypeExprNode *> LHSOrErr =
+      ImportCXXMGTypeExprNode(Importer, ToContext, Node->getLHS());
+  if (!LHSOrErr)
+    return LHSOrErr.takeError();
+
+  Expected<CXXMGTypeExprNode *> RHSOrErr =
+      ImportCXXMGTypeExprNode(Importer, ToContext, Node->getRHS());
+  if (!RHSOrErr)
+    return RHSOrErr.takeError();
+
+  return CXXMGTypeExprNode::CreateBinary(
+      ToContext, Node->getOpcode(), *LHSOrErr, *RHSOrErr, *OpLocOrErr,
+      SourceRange(*BeginOrErr, *EndOrErr));
+}
+
+ExpectedType
+ASTNodeImporter::VisitCXXMGTypeExprType(const CXXMGTypeExprType *T) {
+  Expected<CXXMGTypeExprNode *> NodeOrErr =
+      ImportCXXMGTypeExprNode(Importer, Importer.getToContext(),
+                              T->getTypeExprNode());
+  if (!NodeOrErr)
+    return NodeOrErr.takeError();
+  return Importer.getToContext().getCXXMGTypeExprType(*NodeOrErr);
+}
