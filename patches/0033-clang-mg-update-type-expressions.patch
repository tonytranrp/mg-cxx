From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mike <michaelgorney4@gmail.com>
Date: Sun, 24 May 2026 01:25:15 -0400
Subject: [PATCH 06/12] clang-mg: update type-expressions


diff --git a/clang/lib/Sema/SemaCXXMGTypeExpr.cpp b/clang/lib/Sema/SemaCXXMGTypeExpr.cpp
index ee1cf38cb29c..876cb5dce8a1 100644
--- a/clang/lib/Sema/SemaCXXMGTypeExpr.cpp
+++ b/clang/lib/Sema/SemaCXXMGTypeExpr.cpp
@@ -654,5 +654,17 @@ void Sema::MaybeBindCXXMGTypeExprGeneratedRecordToAlias(TypeAliasDecl *Alias,
   auto *RD = Underlying->getAsCXXRecordDecl();
   if (!RD || !RD->isImplicit())
     return;
+
+  // Do not steal the linkage name from an existing alias.
+  if (TypedefNameDecl *Existing = RD->getTypedefNameForAnonDecl()) {
+    if (Existing != Alias)
+      return;
+  }
+
+  // Microsoft mangling requires the anonymous tag and its typedef-name-for-
+  // linkage to be in the same declaration context.
+  if (RD->getDeclContext() != Alias->getDeclContext())
+    return;
+
   RD->setTypedefNameForAnonDecl(Alias);
 }
diff --git a/clang/lib/Sema/SemaTemplateInstantiateDecl.cpp b/clang/lib/Sema/SemaTemplateInstantiateDecl.cpp
index d234f57f9795..0f983a84a5ae 100644
--- a/clang/lib/Sema/SemaTemplateInstantiateDecl.cpp
+++ b/clang/lib/Sema/SemaTemplateInstantiateDecl.cpp
@@ -1640,7 +1640,7 @@ Decl *TemplateDeclInstantiator::InstantiateTypedefNameDecl(TypedefNameDecl *D,
   if (D->getUnderlyingType()->getAs<DependentNameType>())
     SemaRef.inferGslPointerAttribute(Typedef);
 
-  if (IsTypeAlias)
+  if (IsTypeAlias && D->getUnderlyingType()->getAs<CXXMGTypeExprType>())
     SemaRef.MaybeBindCXXMGTypeExprGeneratedRecordToAlias(
         cast<TypeAliasDecl>(Typedef), TSI->getType());
 
diff --git a/clang/test/CXXMG/type-expressions/type-expr-do-not-rebind-generated-record-alias.cpp b/clang/test/CXXMG/type-expressions/type-expr-do-not-rebind-generated-record-alias.cpp
new file mode 100644
index 000000000000..6816448f3576
--- /dev/null
+++ b/clang/test/CXXMG/type-expressions/type-expr-do-not-rebind-generated-record-alias.cpp
@@ -0,0 +1,40 @@
+// RUN: %clang_cc1 -std=c++14 -fcxxmg -triple x86_64-pc-windows-msvc -emit-llvm-only -verify %s
+
+// expected-no-diagnostics
+
+struct A {
+  int val = 0;
+};
+
+struct B {
+  int poop = 1;
+};
+
+using C = A + B;
+
+template <class T>
+struct decay {
+  using type = T;
+};
+
+template <class T>
+using decay_t = typename decay<T>::type;
+
+template <class T>
+void use_decay(T) {
+  using D = decay_t<C>;
+}
+
+template <class T>
+using Alias = T;
+
+using D = Alias<C>;
+
+template <class T>
+void f(T) {}
+
+void test() {
+  C c{};
+  use_decay(c);
+  f(c);
+}
