+// RUN: not %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only %s -DCASE_UNSUPPORTED 2>&1 | FileCheck %s --check-prefix=BAD-SCHEME
+// RUN: not %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only %s -DCASE_EMPTY_HOST 2>&1 | FileCheck %s --check-prefix=EMPTY-HOST
