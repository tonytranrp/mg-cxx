diff --git a/clang/test/CXXMG/urlinclude/Inputs/urlinclude_fetch.py b/clang/test/CXXMG/urlinclude/Inputs/urlinclude_fetch.py
new file mode 100644
index 000000000000..7fa437e06253
--- /dev/null
+++ b/clang/test/CXXMG/urlinclude/Inputs/urlinclude_fetch.py
@@ -0,0 +1,31 @@
+#!/usr/bin/env python3
+import argparse
+import pathlib
+import sys
+
+parser = argparse.ArgumentParser()
+parser.add_argument("--variant", default="default")
+parser.add_argument("-o", dest="output", required=True)
+parser.add_argument("url")
+args = parser.parse_args()
+
+headers = {
+    ("default", "https://cxxmg.test/basic.hpp"): "#pragma once\nstruct UrlBasic { int value; };\n",
+    ("default", "https://cxxmg.test/quote.hpp"): "#pragma once\nstruct UrlQuote { int value; };\n",
+    ("default", "https://cxxmg.test/angle.hpp"): "#pragma once\nstruct UrlAngle { int value; };\n",
+    ("default", "https://cxxmg.test/pch.hpp"): "#pragma once\nstruct UrlPch { int value; };\n",
+    ("default", "https://cxxmg.test/preprocess.hpp"): "#define URLINCLUDE_PREPROCESS_VALUE 123\n",
+    ("default", "https://cxxmg.test/same-name.hpp?one"): "#pragma once\nstruct UrlSameNameOne { int value; };\n",
+    ("default", "https://cxxmg.test/same-name.hpp?two"): "#pragma once\nstruct UrlSameNameTwo { int value; };\n",
+    ("default", "https://cxxmg.test/with-query.hpp?x=1#frag"): "#pragma once\nstruct UrlQueryFragment { int value; };\n",
+    ("v1", "https://cxxmg.test/refresh.hpp"): "#pragma once\ninline constexpr int urlinclude_refresh_value = 1;\n",
+    ("v2", "https://cxxmg.test/refresh.hpp"): "#pragma once\ninline constexpr int urlinclude_refresh_value = 2;\n",
+    ("default", "http://cxxmg.test/http.hpp"): "#pragma once\nstruct UrlHttp { int value; };\n",
+}
+
+key = (args.variant, args.url)
+if key not in headers:
+    sys.stderr.write(f"unknown test url: {args.url}\n")
+    sys.exit(9)
+
+pathlib.Path(args.output).write_text(headers[key], encoding="utf-8")
