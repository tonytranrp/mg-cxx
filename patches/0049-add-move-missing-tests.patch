     void VisitRequiresExprBodyDecl(RequiresExprBodyDecl *D);
     void VisitTraitRequirementDecl(TraitRequirementDecl *D);
+    void VisitCXXMGConditionalMemberDecl(CXXMGConditionalMemberDecl *D);
