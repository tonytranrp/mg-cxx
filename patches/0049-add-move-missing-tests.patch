diff --git a/clang/test/CXXMG/conditional-members/conditional-member-special-members.cpp b/clang/test/CXXMG/conditional-members/conditional-member-special-members.cpp
new file mode 100644
index 000000000000..44b65506a7fe
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-special-members.cpp
@@ -0,0 +1,57 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+struct NonTrivial { NonTrivial(); };
+
+template <bool Enabled>
+struct MaybeNonTrivial {
+  if constexpr (Enabled) { NonTrivial nt; }
+};
+
+static_assert(!__is_trivially_constructible(MaybeNonTrivial<true>));
+static_assert(__is_trivially_constructible(MaybeNonTrivial<false>));
+
+template <bool Enabled>
+struct MaybeDeletedCopy {
+  if constexpr (Enabled) {
+    MaybeDeletedCopy() = default;
+    MaybeDeletedCopy(const MaybeDeletedCopy &) = delete; // expected-note {{'MaybeDeletedCopy' has been explicitly marked deleted here}}
+  }
+};
+
+void copy_false(MaybeDeletedCopy<false> a) {
+  MaybeDeletedCopy<false> b = a;
+  (void)b;
+}
+
+void copy_true(MaybeDeletedCopy<true> a) {
+  MaybeDeletedCopy<true> b = a; // expected-error {{call to deleted constructor}}
+  (void)b;
+}
+
+template <bool Enabled>
+struct MaybeReference {
+  if constexpr (Enabled) { int &ref; } // expected-note {{default constructor of 'MaybeReference<true>' is implicitly deleted because field 'ref' of reference type 'int &' would not be initialized}}
+};
+
+void default_reference_false() {
+  MaybeReference<false> value;
+  (void)value;
+}
+
+void default_reference_true() {
+  MaybeReference<true> value; // expected-error {{call to implicitly-deleted default constructor}}
+  (void)value;
+}
+
+template <bool Enabled>
+struct MaybeConst {
+  if constexpr (Enabled) { const int value = 0; } // expected-note {{copy assignment operator of 'MaybeConst<true>' is implicitly deleted because field 'value' is of const-qualified type 'const int'}}
+};
+
+void assign_false(MaybeConst<false> a, MaybeConst<false> b) {
+  a = b;
+}
+
+void assign_true(MaybeConst<true> a, MaybeConst<true> b) {
+  a = b; // expected-error {{object of type 'MaybeConst<true>' cannot be assigned}}
+}
