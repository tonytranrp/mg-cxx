diff --git a/clang/test/CXXMG/conditional-members/conditional-member-conflicts.cpp b/clang/test/CXXMG/conditional-members/conditional-member-conflicts.cpp
new file mode 100644
index 000000000000..125c7d781a4e
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-conflicts.cpp
@@ -0,0 +1,36 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+template <bool B>
+struct SameNameExclusive {
+  if constexpr (B) { int value; }
+  else { char value; }
+};
+
+static_assert(__is_same(decltype(SameNameExclusive<true>::value), int));
+static_assert(__is_same(decltype(SameNameExclusive<false>::value), char));
+
+struct InactiveDoesNotConflict {
+  if constexpr (false) { int value; }
+  int value;
+};
+
+struct ActiveConflict {
+  int value; // expected-note {{previous}}
+  if constexpr (true) {
+    int value; // expected-error {{duplicate member 'value'}}
+  }
+};
+
+struct IndependentActiveConflict {
+  if constexpr (true) { int value; } // expected-note {{previous}}
+  if constexpr (true) { int value; } // expected-error {{duplicate member 'value'}}
+};
+
+template <bool B>
+struct AliasExclusive {
+  if constexpr (B) { using type = int; }
+  else { using type = char; }
+};
+
+static_assert(__is_same(typename AliasExclusive<true>::type, int));
+static_assert(__is_same(typename AliasExclusive<false>::type, char));
diff --git a/clang/test/CXXMG/conditional-members/conditional-member-dependent-lookup.cpp b/clang/test/CXXMG/conditional-members/conditional-member-dependent-lookup.cpp
