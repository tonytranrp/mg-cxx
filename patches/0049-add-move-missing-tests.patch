@@ -1900,6 +1902,22 @@ void ASTDeclWriter::VisitTraitRequirementDecl(TraitRequirementDecl *D) {
   Code = serialization::DECL_TRAIT_REQUIREMENT;
 }
 
+void ASTDeclWriter::VisitCXXMGConditionalMemberDecl(
+    CXXMGConditionalMemberDecl *D) {
+  VisitDecl(D);
+  Record.push_back(D->getNumArms());
+  for (const CXXMGConditionalMemberArm &Arm : D->arms()) {
+    Record.AddStmt(Arm.Condition);
+    Record.AddSourceRange(Arm.Range);
+    Record.push_back(Arm.StartAS);
+    Record.push_back(Arm.IsElseArm);
+    Record.push_back(Arm.Decls.size());
+    for (Decl *PatternDecl : Arm.Decls)
+      Record.AddDeclRef(PatternDecl);
+  }
+  Code = serialization::DECL_CXXMG_CONDITIONAL_MEMBER;
+}
