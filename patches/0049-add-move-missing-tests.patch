 void ASTDeclWriter::VisitRedeclarableTemplateDecl(RedeclarableTemplateDecl *D) {
   VisitRedeclarable(D);
 
diff --git a/clang/test/CXXMG/conditional-members/conditional-member-access.cpp b/clang/test/CXXMG/conditional-members/conditional-member-access.cpp
new file mode 100644
index 000000000000..e192474ae79e
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-access.cpp
@@ -0,0 +1,36 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+class Access {
+public:
+  if constexpr (true) { int pub; }
+private:
+  if constexpr (true) { int priv; } // expected-note {{declared private here}}
+protected:
+  if constexpr (true) { int prot; } // expected-note {{declared protected here}}
+public:
+  int after;
+};
+
+struct Derived : Access {
+  void f() { prot = 1; }
+};
+
+void test(Access &a) {
+  a.pub = 1;
+  a.after = 2;
+  a.priv = 3; // expected-error {{'priv' is a private member}}
+  a.prot = 4; // expected-error {{'prot' is a protected member}}
+}
+
+struct StructDefaultAccess {
+  if constexpr (true) { int value; }
+};
+
+class ClassDefaultAccess {
+  if constexpr (true) { int value; } // expected-note {{implicitly declared private here}}
+};
+
+void defaults(StructDefaultAccess &s, ClassDefaultAccess &c) {
+  s.value = 1;
+  c.value = 2; // expected-error {{'value' is a private member}}
+}
