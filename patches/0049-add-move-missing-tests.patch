diff --git a/clang/test/CXXMG/conditional-members/conditional-member-member-kinds.cpp b/clang/test/CXXMG/conditional-members/conditional-member-member-kinds.cpp
new file mode 100644
index 000000000000..29fa959b8f38
--- /dev/null
+++ b/clang/test/CXXMG/conditional-members/conditional-member-member-kinds.cpp
@@ -0,0 +1,43 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+struct Base {
+  int inherited;
+};
+
+template <bool Enabled>
+struct Kinds : Base {
+  if constexpr (Enabled) {
+    int field;
+    static int static_data;
+    void method() {}
+    static constexpr int static_method() { return 1; }
+    using type = int;
+    struct Nested { int x; };
+    enum E { enumerator = 7 };
+    using Base::inherited;
+    template <class T> using AliasTemplate = T;
+  } else {
+    char fallback;
+  }
+};
+
+static_assert(__is_same(typename Kinds<true>::type, int));
+static_assert(Kinds<true>::static_method() == 1);
+static_assert(Kinds<true>::enumerator == 7);
+static_assert(__is_same(typename Kinds<true>::template AliasTemplate<long>, long));
+
+void enabled(Kinds<true> &k) {
+  k.field = 1;
+  k.method();
+  k.inherited = 2;
+  Kinds<true>::Nested n = {3};
+  (void)n;
+}
+
+void disabled(Kinds<false> &k) {
+  k.fallback = 1;
+  (void)k.field; // expected-error {{no member named 'field'}}
+  k.method(); // expected-error {{no member named 'method'}}
+}
+
+using DisabledType = typename Kinds<false>::type; // expected-error {{no type named 'type'}}
