@@ -0,0 +1,64 @@
+// RUN: %clang_cc1 -std=c++20 -fcxxmg -fsyntax-only -verify %s
+
+template <bool Enabled>
+struct DepLookup {
+  if constexpr (Enabled) {
+    int value;
+    using type = int;
+  } else {
+    int fallback;
+  }
+
+  int implicit_this() {
+    if constexpr (Enabled)
+      return value;
+    else
+      return fallback;
+  }
+
+  int explicit_this() {
+    if constexpr (Enabled)
+      return this->value; // expected-error {{no member named 'value'}}
+    else
+      return this->fallback; // expected-error {{no member named 'fallback'}}
+  }
+
+  int const_member() const {
+    if constexpr (Enabled)
+      return value;
+    else
+      return fallback;
+  }
+
+  template <class T>
+  int member_template() {
+    if constexpr (Enabled)
+      return value;
+    else
+      return fallback;
+  }
+
+  int typo() {
+    return valu; // expected-error {{use of undeclared identifier 'valu'}}
+  }
+
+  void value_as_type() {
+    typename DepLookup::value *p; // expected-error {{no type named 'value'}}
+  }
+};
+
+template struct DepLookup<true>;
+template struct DepLookup<false>;
+
+template <class T>
+struct KnownFalseArmStillHidden {
+  if constexpr (false) {
+    int never;
+  }
+
+  void f() {
+    never = 1; // expected-error {{use of undeclared identifier 'never'}}
+  }
+};
+
+template struct KnownFalseArmStillHidden<int>;
