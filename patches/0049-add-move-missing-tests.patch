diff --git a/clang/lib/AST/DeclCXXMG.cpp b/clang/lib/AST/DeclCXXMG.cpp
index 7b4450f48b5e..a097e4dfe7e5 100644
--- a/clang/lib/AST/DeclCXXMG.cpp
+++ b/clang/lib/AST/DeclCXXMG.cpp
@@ -45,4 +45,23 @@ CXXMGConditionalMemberDecl::Create(
   }
 
   return D;
-}
\ No newline at end of file
+}
+
+CXXMGConditionalMemberDecl *
+CXXMGConditionalMemberDecl::CreateDeserialized(ASTContext &Ctx,
+                                               GlobalDeclID ID) {
+  return new (Ctx, ID) CXXMGConditionalMemberDecl(nullptr, SourceLocation());
+}
+
+void CXXMGConditionalMemberDecl::addDeserializedArm(
+    ASTContext &Ctx, const CXXMGConditionalMemberArm &Arm) {
+  unsigned FirstDecl = OwnedDecls.size();
+  OwnedDecls.append(Ctx, Arm.Decls.begin(), Arm.Decls.end());
+
+  llvm::ArrayRef<Decl *> StableDecls(OwnedDecls.begin() + FirstDecl,
+                                     Arm.Decls.size());
+  Arms.push_back(CXXMGConditionalMemberArm{Arm.Condition, StableDecls,
+                                           Arm.StartAS, Arm.Range,
+                                           Arm.IsElseArm},
+                 Ctx);
+}
