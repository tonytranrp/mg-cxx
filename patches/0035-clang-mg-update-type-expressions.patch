+static bool DiagnoseCXXMGGeneratedRecordNameCollision(
+    Sema &S, Scope *Sc, const IdentifierInfo *II, SourceLocation NameLoc) {
+  LookupResult Previous(S, DeclarationName(II), NameLoc,
+                        Sema::LookupOrdinaryName,
+                        RedeclarationKind::NotForRedeclaration);
+  S.LookupName(Previous, Sc);
+
+  if (Previous.empty())
+    return false;
+
+  S.Diag(NameLoc, diag::err_redefinition_different_kind) << II;
+  S.Diag(Previous.getRepresentativeDecl()->getLocation(),
+         diag::note_previous_definition);
+  return true;
+}
