+    auto *RD =
+        CXXRecordDecl::Create(Ctx, Kind, S.CurContext, StartLoc, NameLoc,
+                              const_cast<IdentifierInfo *>(Name));
+
+    RD->setAccess(AS);
+    S.PushOnScopeChains(RD, Sc);
