+
+// expected-no-diagnostics
+
+template <class T>
+struct A {
+  T value{};
+};
+
+struct B {
+  int extra = 1;
+};
+
+template <class T>
+using C = A<T> + B;
+
+static_assert(__is_same(decltype(C<int>{}.value), int));
+static_assert(__is_same(decltype(C<float>{}.value), float));
