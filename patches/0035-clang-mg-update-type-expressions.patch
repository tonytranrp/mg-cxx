+Decl *Sema::ActOnCXXMGTypeExpressionRecordDeclaration(
+    Scope *CurScope, AccessSpecifier AS, MultiTemplateParamsArg TemplateParams,
+    SourceLocation UsingLoc, UnqualifiedId &Name,
+    const ParsedAttributesView &AttrList, const ParsedCXXMGTypeExpr &TE) {
+  if (!getLangOpts().CPlusPlusMG) {
+    Diag(UsingLoc, diag::err_cxxmg_type_expr_requires_cxxmg);
+    return nullptr;
+  }
+
+  if (Name.getKind() != UnqualifiedIdKind::IK_Identifier) {
+    Diag(Name.StartLocation, diag::err_typedef_not_identifier);
+    return nullptr;
+  }
+
+  const IdentifierInfo *II = Name.Identifier;
+  SourceLocation NameLoc = Name.StartLocation;
+
+  CXXMGTypeExprNode *Node = BuildCXXMGTypeExprNode(CurScope, TE);
+  if (!Node)
+    return nullptr;
+
+  CXXMGTypeExprSema Impl(*this);
+
+  if (!TemplateParams.empty())
+    return Impl.synthesizeClassTemplatePattern(CurScope, UsingLoc, NameLoc, II,
+                                               AS, TemplateParams, AttrList,
+                                               Node);
+
+  if (Node->isDependent() || Node->isInstantiationDependent()) {
+    Diag(UsingLoc, diag::err_cxxmg_type_expr_dependent_non_template);
+    return nullptr;
+  }
+
+  if (DiagnoseCXXMGGeneratedRecordNameCollision(*this, CurScope, II, NameLoc))
+    return nullptr;
+
+  CXXMGMemberSet Set = Impl.buildSet(Node);
+  if (Set.Invalid)
+    return nullptr;
+
+  return Impl.synthesizeNamedRecord(CurScope, UsingLoc, NameLoc, II, AS,
+                                    AttrList, Node, Set);
+}
+
+bool Sema::InstantiateCXXMGTypeExpressionClassTemplateSpecialization(
+    SourceLocation PointOfInstantiation,
+    ClassTemplateSpecializationDecl *ClassTemplateSpec, CXXRecordDecl *Pattern,
+    const MultiLevelTemplateArgumentList &TemplateArgs,
+    TemplateSpecializationKind TSK, bool Complain) {
+  (void)Complain;
+  if (!Pattern || !Pattern->getCXXMGTypeExpressionPattern())
+    return true;
+
+  NonSFINAEContext NonSFINAE(*this);
+  InstantiatingTemplate Inst(*this, PointOfInstantiation, ClassTemplateSpec);
+  if (Inst.isInvalid())
+    return true;
+
+  CXXMGTypeExprNode *PatternNode = Pattern->getCXXMGTypeExpressionPattern();
+
+  LocalInstantiationScope Scope(*this);
+
+  CXXMGTypeExprNode *SubstNode =
+      SubstCXXMGTypeExprNode(PatternNode, TemplateArgs);
+  if (!SubstNode)
+    return true;
+
+  if (SubstNode->isDependent() || SubstNode->isInstantiationDependent()) {
+    if (!ClassTemplateSpec->hasDefinition())
+      ClassTemplateSpec->startDefinition();
+    ClassTemplateSpec->setCXXMGTypeExpressionPattern(SubstNode);
+    return false;
+  }
+
+  ClassTemplateSpec->setTemplateSpecializationKind(TSK);
+  ClassTemplateSpec->setPointOfInstantiation(PointOfInstantiation);
+
+  CXXMGTypeExprSema Impl(*this);
+  CXXMGMemberSet Set = Impl.buildSet(SubstNode);
+  if (Set.Invalid)
+    return true;
+
+  ContextRAII SavedContext(*this, ClassTemplateSpec);
+
+  bool Err = Impl.synthesizeIntoRecord(/*Sc=*/nullptr, ClassTemplateSpec,
+                                       PointOfInstantiation, Set,
+                                       /*NotifyConsumer=*/true);
+  if (Err)
+    ClassTemplateSpec->setInvalidDecl();
+  else
+    ClassTemplateSpec->setCXXMGTypeExpressionPattern(SubstNode);
+
+  return Err;
+}
