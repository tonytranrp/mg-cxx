+  Decl *synthesizeClassTemplatePattern(
+      Scope *Sc, SourceLocation StartLoc, SourceLocation NameLoc,
+      const IdentifierInfo *Name, AccessSpecifier AS,
+      MultiTemplateParamsArg TemplateParams,
+      const ParsedAttributesView &AttrList,
+      CXXMGTypeExprNode *PatternNode) {
+    if (TemplateParams.empty())
+      return nullptr;
+
+    if (TemplateParams.size() != 1) {
+      S.Diag(StartLoc, diag::err_cxxmg_type_expr_nested_template_params);
+      return nullptr;
+    }
+
+    if (DiagnoseCXXMGGeneratedRecordNameCollision(S, Sc, Name, NameLoc))
+      return nullptr;
+
+    TemplateParameterList *Params = TemplateParams[0];
+
+    auto *RD = CXXRecordDecl::Create(Ctx, TagTypeKind::Struct, S.CurContext,
+                                     StartLoc, NameLoc,
+                                     const_cast<IdentifierInfo *>(Name));
+    RD->setAccess(AS);
+    RD->startDefinition();
+    RD->setCXXMGTypeExpressionPattern(PatternNode);
+
+    auto *CTD = ClassTemplateDecl::Create(Ctx, S.CurContext, NameLoc,
+                                          DeclarationName(Name), Params, RD);
+    RD->setDescribedClassTemplate(CTD);
+
+    if (!AttrList.empty())
+      S.ProcessDeclAttributeList(Sc, CTD, AttrList);
+
+    S.PushOnScopeChains(CTD, Sc);
+    SmallVector<Decl *, 1> Fields;
+    S.ActOnFields(Sc, StartLoc, RD, Fields, StartLoc, StartLoc,
+                  ParsedAttributesView());
+    S.CheckCompletedCXXClass(Sc, RD);
+    if (!RD->isInvalidDecl())
+      S.Consumer.HandleTagDeclDefinition(RD);
+
+    return CTD;
+  }
